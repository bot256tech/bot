PORT=3000
NODE_ENV=production

# PostgreSQL Database (Connection String — recommended)
DATABASE_URL=postgresql://user:password@host:5432/agrichain360

# PostgreSQL Database (Individual fields — alternative)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agrichain360
DB_USER=postgres
DB_PASSWORD=your_secure_password

# JWT Authentication (CHANGE THIS IN PRODUCTION)
JWT_SECRET=your_super_secret_jwt_key_here

# Session Secret (CHANGE THIS IN PRODUCTION)
SESSION_SECRET=your_session_secret_here

# MQTT Broker (for IoT solar dryers)
MQTT_BROKER_URL=mqtt://localhost:1883
