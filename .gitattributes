# Force LF line endings for all text files (prevents CRLF warnings)
* text=auto eol=lf

# Explicitly set text files
*.js text eol=lf
*.json text eol=lf
*.ejs text eol=lf
*.css text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.html text eol=lf
*.env* text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.config text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files (don't touch)
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
