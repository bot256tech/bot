{
  "expo": {
    "name": "AGRICHAIN 360",
    "slug": "agrichain360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1B5E20"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrichain360.app",
      "infoPlist": {
        "NSCameraUsageDescription": "AGRICHAIN 360 needs camera access to scan crop diseases and QR codes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20"
      },
      "package": "com.agrichain360.app",
      "permissions": ["CAMERA", "ACCESS_FINE_LOCATION"]
    },
    "plugins": [
      "expo-camera",
      "expo-location"
    ]
  }
}
