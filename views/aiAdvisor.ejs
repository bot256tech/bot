<div class="grid grid2">
  <div class="card">
    <h3 style="font-weight:800;margin-bottom:16px">🤖 AI Crop Advisor — Real-time Insights</h3>
    
    <div class="chat" id="aiChat" style="height:320px;margin-bottom:16px">
      <div class="chat-msg">
        <div class="chat-bub ai">Hello! I’m AgriIntel AI. Ask me anything about harvest timing, drying, markets, or disease risk for your crops in Jinja, Iganga, Kamuli or Mayuge.</div>
      </div>
    </div>
    
    <div style="display:flex;gap:8px">
      <input id="aiInput" type="text" placeholder="Ask about harvest timing, markets, drying..." style="flex:1;padding:12px 16px;border-radius:50px" onkeypress="if(event.key==='Enter')askAI()">
      <button class="btn btn-p" onclick="askAI()">Ask AI</button>
    </div>
    
    <div style="margin-top:16px">
      <div style="font-size:.75rem;color:var(--tx2);margin-bottom:6px">Quick questions:</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        <button class="btn btn-o btn-sm" onclick="quickAsk(0)">When to harvest maize?</button>
        <button class="btn btn-o btn-sm" onclick="quickAsk(1)">Disease risk?</button>
        <button class="btn btn-o btn-sm" onclick="quickAsk(2)">Best groundnut market?</button>
        <button class="btn btn-o btn-sm" onclick="quickAsk(3)">Drying cost?</button>
      </div>
    </div>
  </div>
  
  <div class="card">
    <h3 style="font-weight:800;margin-bottom:12px">📋 Sample AI Responses (Live Database)</h3>
    <div style="font-size:.85rem;line-height:1.65">
      <% aiAdvice.forEach(function(a,i) { %>
        <div style="margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--bd)">
          <div style="font-weight:700;color:var(--g)">Q: <%= a.q %></div>
          <div style="margin-top:4px"><%= a.a %></div>
        </div>
      <% }) %>
    </div>
  </div>
</div>