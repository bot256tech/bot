<div class="grid grid2">
  <div class="card">
    <h3 style="font-weight:800;margin-bottom:16px">🌱 AI Growth Stage & Yield Prediction</h3>
    
    <div style="margin-bottom:20px">
      <label style="font-size:.85rem;display:block;margin-bottom:6px">Upload crop photo</label>
      <input type="file" id="growthPhoto" accept="image/*" onchange="analyzeGrowth(this)" style="width:100%">
    </div>
    
    <div id="growthResult" style="display:none"></div>
  </div>
  
  <div class="card">
    <h3 style="font-weight:800;margin-bottom:16px">📊 Yield & Quality Prediction</h3>
    
    <div class="grid grid3" style="gap:12px">
      <div class="metric"><div class="metric-val" id="predYield">2.8</div><div class="metric-lbl">Tons/ha</div></div>
      <div class="metric"><div class="metric-val" id="predValue">UGX 5.2M</div><div class="metric-lbl">Est. Revenue</div></div>
      <div class="metric"><div class="metric-val" id="predGrade">A</div><div class="metric-lbl">Quality Grade</div></div>
    </div>
    
    <div style="margin-top:20px;font-size:.85rem">
      <div><strong>Harvest Window:</strong> <span id="harvestDate">18–24 Aug 2026</span></div>
      <div><strong>Export Ready:</strong> <span class="tag tag-g">Yes</span></div>
      <div><strong>Risk Level:</strong> <span style="color:#e65100">Low</span></div>
    </div>
  </div>
</div>

<script>
function analyzeGrowth(input) {
  if (!input.files.length) return;
  
  const resultDiv = document.getElementById('growthResult');
  resultDiv.style.display = 'block';
  resultDiv.innerHTML = `
    <div style="margin-top:16px">
      <div style="font-weight:700;margin-bottom:8px">AI Analysis Complete</div>
      
      <div style="display:flex;gap:12px;margin-bottom:14px">
        <div style="flex:1"><strong>Detected Stage:</strong><br> <span style="color:var(--g)">Late Vegetative → Flowering</span></div>
        <div style="flex:1"><strong>Plant Age:</strong><br> 78 days</div>
      </div>
      
      <div style="background:#f8f9f8;padding:12px;border-radius:10px">
        <div style="margin-bottom:8px"><strong>Health Score:</strong> <span style="font-weight:800">91/100</span></div>
        <div class="progress"><div class="progress-fill g" style="width:91%"></div></div>
      </div>
      
      <div style="margin-top:14px;font-size:.85rem">
        <div>• Water Stress: <strong>Low</strong></div>
        <div>• Nutrition: <strong>Good</strong></div>
        <div>• Expected Harvest: <strong>22 Aug ± 4 days</strong></div>
        <div>• Predicted Yield: <strong>2.8 tons/ha</strong></div>
      </div>
    </div>
  `;
  
  // Update prediction cards
  document.getElementById('predYield').innerText = (2.4 + Math.random() * 0.8).toFixed(1);
  document.getElementById('predValue').innerText = 'UGX ' + (4.8 + Math.random() * 1.2).toFixed(1) + 'M';
}
</script>