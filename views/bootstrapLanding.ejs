<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AGRICHAIN 360™ — The Digital Infrastructure Powering Agriculture Across Africa</title>
<meta name="description" content="AGRICHAIN 360 connects farmers, cooperatives, buyers, transporters, warehouses, exporters, financial institutions, NGOs, and governments through one intelligent digital ecosystem.">
<meta name="theme-color" content="#1B5E20">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
/* ═══════════════════════════════════════════════════════════
   AGRICHAIN 360™ — NATIONAL INFRASTRUCTURE DESIGN SYSTEM
   Inspired by: Stripe, Linear, Palantir, Notion + Agricultural Warmth
   ═══════════════════════════════════════════════════════════ */

:root {
  --green: #1B5E20;
  --green-mid: #2E7D32;
  --green-light: #4CAF50;
  --green-pale: #E8F5E9;
  --gold: #D4AF37;
  --gold-light: #F5E6A3;
  --gold-dark: #B8960C;
  --cream: #FAFAF5;
  --white: #FFFFFF;
  --gray-50: #F8F9FA;
  --gray-100: #F1F3F5;
  --gray-200: #E9ECEF;
  --gray-300: #DEE2E6;
  --gray-400: #CED4DA;
  --gray-500: #ADB5BD;
  --gray-600: #6C757D;
  --gray-700: #495057;
  --gray-800: #343A40;
  --charcoal: #333333;
  --shadow-sm: 0 1px 3px rgba(0,0,0,.06);
  --shadow-md: 0 4px 16px rgba(0,0,0,.08);
  --shadow-lg: 0 12px 40px rgba(0,0,0,.1);
  --shadow-xl: 0 24px 60px rgba(0,0,0,.12);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 20px;
  --radius-xl: 28px;
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  background: var(--cream);
  color: var(--charcoal);
  overflow-x: hidden;
  line-height: 1.6;
}

/* Typography */
h1,h2,h3,h4,h5 { font-family: 'Playfair Display', Georgia, serif; letter-spacing: -.02em; line-height: 1.15; }
.serif { font-family: 'Playfair Display', Georgia, serif; }
.sans { font-family: 'Inter', system-ui, sans-serif; }

/* Scroll Animations */
.reveal { opacity:0; transform:translateY(40px); transition: opacity .8s cubic-bezier(.25,.8,.25,1), transform .8s cubic-bezier(.25,.8,.25,1); }
.reveal.visible { opacity:1; transform:translateY(0); }
.reveal-left { opacity:0; transform:translateX(-40px); transition: opacity .8s ease, transform .8s ease; }
.reveal-left.visible { opacity:1; transform:translateX(0); }
.reveal-right { opacity:0; transform:translateX(40px); transition: opacity .8s ease, transform .8s ease; }
.reveal-right.visible { opacity:1; transform:translateX(0); }
.reveal-scale { opacity:0; transform:scale(.92); transition: opacity .7s ease, transform .7s ease; }
.reveal-scale.visible { opacity:1; transform:scale(1); }
.d1{transition-delay:.1s!important} .d2{transition-delay:.2s!important} .d3{transition-delay:.3s!important}
.d4{transition-delay:.4s!important} .d5{transition-delay:.5s!important} .d6{transition-delay:.6s!important}
.d7{transition-delay:.7s!important} .d8{transition-delay:.8s!important}

/* ═══════════════ NAVBAR ═══════════════ */
.nav {
  position: fixed; top:0; left:0; right:0; z-index:1000;
  background: rgba(250,250,245,.92);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(27,94,32,.08);
  transition: all .3s ease;
}
.nav.scrolled { box-shadow: 0 1px 12px rgba(0,0,0,.06); }
.nav-inner {
  display:flex; align-items:center; justify-content:space-between;
  max-width:1280px; margin:0 auto; padding:0 32px; height:72px;
}
.nav-brand {
  font-family:'Playfair Display',serif; font-weight:800; font-size:1.2rem;
  color:var(--green); text-decoration:none; display:flex; align-items:center; gap:8px;
}
.nav-brand .logo-dot { width:10px; height:10px; background:var(--gold); border-radius:50%; display:inline-block; }
.nav-links { display:flex; align-items:center; gap:4px; }
.nav-links a {
  padding:8px 16px; border-radius:8px; font-size:.875rem; font-weight:500;
  color:var(--gray-600); text-decoration:none; transition:all .2s;
}
.nav-links a:hover { color:var(--green); background:var(--green-pale); }
.nav-cta {
  padding:10px 24px !important; border-radius:10px !important;
  background:var(--green) !important; color:white !important; font-weight:600 !important;
  box-shadow: 0 2px 8px rgba(27,94,32,.2);
}
.nav-cta:hover { background:var(--green-mid) !important; transform:translateY(-1px); box-shadow: 0 4px 16px rgba(27,94,32,.3); }
.nav-mob { display:none; background:none; border:none; font-size:1.3rem; color:var(--charcoal); cursor:pointer; }
@media(max-width:900px) {
  .nav-links a:not(.nav-cta) { display:none; }
  .nav-mob { display:block; }
  .nav-inner { padding:0 20px; }
}

/* Mobile Drawer */
.mob-drawer {
  position:fixed; top:0; right:-100%; width:300px; height:100vh;
  background:white; z-index:2000; box-shadow:-4px 0 30px rgba(0,0,0,.15);
  transition:right .35s cubic-bezier(.25,.8,.25,1); padding:24px;
  display:flex; flex-direction:column; gap:4px;
}
.mob-drawer.open { right:0; }
.mob-overlay { position:fixed; inset:0; background:rgba(0,0,0,.4); z-index:1999; opacity:0; visibility:hidden; transition:all .3s; }
.mob-overlay.open { opacity:1; visibility:visible; }
.mob-close { align-self:flex-end; background:none; border:none; font-size:1.5rem; cursor:pointer; color:var(--gray-500); margin-bottom:16px; }
.mob-drawer a { display:block; padding:14px 16px; border-radius:12px; font-weight:600; color:var(--charcoal); text-decoration:none; transition:background .2s; }
.mob-drawer a:hover { background:var(--green-pale); color:var(--green); }

/* ═══════════════ HERO SECTION ═══════════════ */
.hero {
  padding: 140px 0 80px;
  background: var(--cream);
  position: relative;
  overflow: hidden;
}
.hero::before {
  content:''; position:absolute; top:-200px; right:-200px;
  width:600px; height:600px; border-radius:50%;
  background: radial-gradient(circle, rgba(212,175,55,.06), transparent 70%);
  pointer-events:none;
}
.hero::after {
  content:''; position:absolute; bottom:-100px; left:-100px;
  width:400px; height:400px; border-radius:50%;
  background: radial-gradient(circle, rgba(27,94,32,.04), transparent 70%);
  pointer-events:none;
}
.hero-grid {
  display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;
  max-width:1280px; margin:0 auto; padding:0 32px; position:relative; z-index:2;
}
.hero-badge {
  display:inline-flex; align-items:center; gap:8px;
  padding:6px 16px; border-radius:50px; font-size:.8rem; font-weight:600;
  background:var(--green-pale); color:var(--green); margin-bottom:24px;
  border: 1px solid rgba(27,94,32,.12);
}
.hero-badge .dot { width:6px; height:6px; background:var(--green-light); border-radius:50%; animation:pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
.hero h1 {
  font-size:3.2rem; font-weight:800; color:var(--charcoal); margin-bottom:20px; line-height:1.1;
}
.hero h1 .gold { color:var(--gold-dark); }
.hero-sub {
  font-size:1.1rem; color:var(--gray-600); line-height:1.7; margin-bottom:32px; max-width:520px;
}
.hero-btns { display:flex; gap:12px; flex-wrap:wrap; }
.btn-hero {
  padding:14px 28px; border-radius:12px; font-weight:600; font-size:.95rem;
  border:none; cursor:pointer; transition:all .3s; text-decoration:none; display:inline-flex; align-items:center; gap:8px;
}
.btn-primary { background:var(--green); color:white; box-shadow:0 4px 16px rgba(27,94,32,.2); }
.btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(27,94,32,.3); color:white; }
.btn-gold { background:var(--gold); color:#3e2723; box-shadow:0 4px 16px rgba(212,175,55,.25); }
.btn-gold:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(212,175,55,.35); color:#3e2723; }
.btn-outline { background:transparent; color:var(--charcoal); border:2px solid var(--gray-300); }
.btn-outline:hover { border-color:var(--green); color:var(--green); }

/* Animated Dashboard Mockup */
.hero-visual { position:relative; }
.dash-mockup {
  background:white; border-radius:var(--radius-lg); padding:24px;
  box-shadow:var(--shadow-xl); border:1px solid var(--gray-200);
  position:relative; overflow:hidden;
}
.dash-mockup::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg, var(--green), var(--gold), var(--green-light));
}
.dash-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
.dash-title { font-family:'Inter',sans-serif; font-weight:700; font-size:.9rem; color:var(--charcoal); }
.dash-live { display:flex; align-items:center; gap:6px; font-size:.75rem; color:var(--green); font-weight:600; }
.dash-live .dot { width:6px; height:6px; background:var(--green-light); border-radius:50%; animation:pulse 2s infinite; }
.dash-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:16px; }
.dash-stat {
  background:var(--gray-50); border-radius:var(--radius-sm); padding:14px; text-align:center;
  border:1px solid var(--gray-100);
}
.dash-stat-val { font-family:'Playfair Display',serif; font-size:1.4rem; font-weight:800; color:var(--green); }
.dash-stat-lbl { font-size:.7rem; color:var(--gray-500); margin-top:2px; text-transform:uppercase; letter-spacing:.05em; }
.dash-chart {
  background:var(--gray-50); border-radius:var(--radius-sm); padding:16px; height:100px;
  border:1px solid var(--gray-100); position:relative; overflow:hidden;
}
.dash-chart-bars {
  display:flex; align-items:flex-end; gap:6px; height:60px; padding-top:8px;
}
.dash-bar {
  flex:1; background:var(--green-pale); border-radius:4px 4px 0 0; transition:height .8s ease;
  position:relative;
}
.dash-bar.gold { background:var(--gold-light); }
.dash-bar.active { background:var(--green); }
.dash-feed { margin-top:12px; }
.dash-feed-item {
  display:flex; align-items:center; gap:10px; padding:8px 0;
  border-bottom:1px solid var(--gray-100); font-size:.78rem; color:var(--gray-600);
  animation: feedSlide .5s ease-out;
}
@keyframes feedSlide { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:translateX(0)} }
.dash-feed-icon { width:28px; height:28px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:.7rem; flex-shrink:0; }
.dash-feed-icon.green { background:var(--green-pale); color:var(--green); }
.dash-feed-icon.gold { background:var(--gold-light); color:var(--gold-dark); }
.dash-feed-icon.blue { background:#E3F2FD; color:#1565C0; }

/* Floating notification cards */
.float-card {
  position:absolute; background:white; border-radius:var(--radius-md); padding:12px 16px;
  box-shadow:var(--shadow-lg); border:1px solid var(--gray-200); font-size:.78rem;
  display:flex; align-items:center; gap:10px; animation:floatCard 3s ease-in-out infinite;
  z-index:3;
}
@keyframes floatCard { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
.float-card.fc1 { top:-20px; right:-30px; animation-delay:0s; }
.float-card.fc2 { bottom:40px; left:-40px; animation-delay:1.5s; }
.float-card .fc-icon { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; }
.float-card .fc-icon.green { background:var(--green-pale); color:var(--green); }
.float-card .fc-icon.gold { background:var(--gold-light); color:var(--gold-dark); }

@media(max-width:900px) {
  .hero { padding:110px 0 60px; }
  .hero-grid { grid-template-columns:1fr; gap:40px; }
  .hero h1 { font-size:2.2rem; }
  .hero-sub { font-size:1rem; }
  .float-card { display:none; }
  .hero-visual { order:-1; }
}
@media(max-width:480px) {
  .hero h1 { font-size:1.8rem; }
  .hero-btns { flex-direction:column; }
  .btn-hero { width:100%; justify-content:center; }
  .dash-stats { grid-template-columns:1fr; }
}

/* ═══════════════ SECTION SHARED ═══════════════ */
.section { padding:100px 0; position:relative; }
.section-sm { padding:60px 0; }
.container { max-width:1280px; margin:0 auto; padding:0 32px; }
.section-label {
  display:inline-flex; align-items:center; gap:8px; font-size:.75rem; font-weight:700;
  text-transform:uppercase; letter-spacing:.1em; color:var(--gold-dark); margin-bottom:12px;
}
.section-label .line { width:32px; height:2px; background:var(--gold); border-radius:2px; }
.section-title { font-size:2.4rem; font-weight:800; margin-bottom:16px; color:var(--charcoal); }
.section-sub { font-size:1.05rem; color:var(--gray-600); line-height:1.7; max-width:640px; margin-bottom:48px; }
.section-center { text-align:center; }
.section-center .section-sub { margin-left:auto; margin-right:auto; }
@media(max-width:768px) {
  .section { padding:60px 0; }
  .section-title { font-size:1.6rem; }
  .section-sub { font-size:.95rem; margin-bottom:32px; }
  .container { padding:0 20px; }
}

/* ═══════════════ LIVE STATS SECTION ═══════════════ */
.stats-section { background:var(--green); color:white; padding:80px 0; position:relative; overflow:hidden; }
.stats-section::before {
  content:''; position:absolute; inset:0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='30' cy='30' r='1' fill='white' opacity='.06'/%3E%3C/svg%3E");
}
.stats-grid {
  display:grid; grid-template-columns:repeat(5,1fr); gap:24px; position:relative; z-index:2;
}
.stat-item { text-align:center; }
.stat-number {
  font-family:'Playfair Display',serif; font-size:2.8rem; font-weight:900; line-height:1;
  display:block; margin-bottom:8px;
}
.stat-number.gold { color:var(--gold); }
.stat-label { font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.08em; }
.stats-note { text-align:center; margin-top:32px; font-size:.8rem; opacity:.5; position:relative; z-index:2; }
@media(max-width:900px) { .stats-grid { grid-template-columns:repeat(3,1fr); gap:20px; } .stat-number { font-size:2rem; } }
@media(max-width:480px) { .stats-grid { grid-template-columns:repeat(2,1fr); } .stat-number { font-size:1.6rem; } }

/* ═══════════════ SUPPLY CHAIN JOURNEY ═══════════════ */
.chain-section { background:white; }
.chain-scroll {
  display:flex; gap:0; overflow-x:auto; padding:20px 0 40px;
  scrollbar-width:thin; scrollbar-color:var(--green-pale) transparent;
}
.chain-scroll::-webkit-scrollbar { height:6px; }
.chain-scroll::-webkit-scrollbar-thumb { background:var(--green-pale); border-radius:3px; }
.chain-step {
  flex:0 0 160px; text-align:center; position:relative; padding:20px 10px;
  cursor:pointer; transition:all .3s;
}
.chain-step:hover { transform:translateY(-4px); }
.chain-step::after {
  content:'→'; position:absolute; right:-8px; top:50%; transform:translateY(-50%);
  color:var(--gray-300); font-size:1.2rem; font-weight:300;
}
.chain-step:last-child::after { display:none; }
.chain-icon {
  width:56px; height:56px; border-radius:16px; display:flex; align-items:center; justify-content:center;
  margin:0 auto 12px; font-size:1.4rem; transition:all .3s;
  background:var(--gray-50); border:2px solid var(--gray-200);
}
.chain-step:hover .chain-icon { background:var(--green-pale); border-color:var(--green); transform:scale(1.1); }
.chain-step.active .chain-icon { background:var(--green); border-color:var(--green); color:white; }
.chain-name { font-weight:600; font-size:.82rem; color:var(--charcoal); }
.chain-desc { font-size:.7rem; color:var(--gray-500); margin-top:4px; }

/* Chain info card (appears on click) */
.chain-info {
  display:none; position:absolute; bottom:100%; left:50%; transform:translateX(-50%);
  background:white; border-radius:var(--radius-md); padding:16px; width:240px;
  box-shadow:var(--shadow-lg); border:1px solid var(--gray-200); z-index:10;
  font-size:.8rem; text-align:left;
}
.chain-info.show { display:block; animation:fadeIn .3s ease; }
@keyframes fadeIn { from{opacity:0;transform:translateX(-50%) translateY(8px)} to{opacity:1;transform:translateX(-50%) translateY(0)} }

/* ═══════════════ STAKEHOLDER ECOSYSTEM ═══════════════ */
.stake-grid {
  display:grid; grid-template-columns:repeat(5,1fr); gap:16px;
}
.stake-card {
  background:white; border-radius:var(--radius-md); padding:24px 16px; text-align:center;
  border:1px solid var(--gray-200); transition:all .35s cubic-bezier(.25,.8,.25,1);
  cursor:pointer; position:relative; overflow:hidden;
}
.stake-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:var(--green); transform:scaleX(0); transition:transform .3s; transform-origin:left;
}
.stake-card:hover { transform:translateY(-6px); box-shadow:var(--shadow-lg); border-color:var(--green); }
.stake-card:hover::before { transform:scaleX(1); }
.stake-emoji { font-size:2rem; margin-bottom:10px; display:block; }
.stake-name { font-weight:700; font-size:.88rem; margin-bottom:4px; }
.stake-desc { font-size:.72rem; color:var(--gray-500); line-height:1.4; }
.stake-services {
  display:none; margin-top:12px; padding-top:12px; border-top:1px solid var(--gray-100);
  font-size:.72rem; color:var(--gray-600); text-align:left;
}
.stake-card:hover .stake-services { display:block; }
@media(max-width:900px) { .stake-grid { grid-template-columns:repeat(3,1fr); } }
@media(max-width:600px) { .stake-grid { grid-template-columns:repeat(2,1fr); } }

/* ═══════════════ AI PREVIEW ═══════════════ */
.ai-section { background:var(--gray-50); }
.ai-grid { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
.ai-chat-mock {
  background:white; border-radius:var(--radius-lg); padding:24px;
  box-shadow:var(--shadow-md); border:1px solid var(--gray-200);
}
.ai-chat-header {
  display:flex; align-items:center; gap:12px; padding-bottom:16px;
  border-bottom:1px solid var(--gray-100); margin-bottom:16px;
}
.ai-avatar {
  width:40px; height:40px; border-radius:12px; background:var(--green);
  display:flex; align-items:center; justify-content:center; color:white; font-size:1rem;
}
.ai-name { font-weight:700; font-size:.9rem; }
.ai-status { font-size:.72rem; color:var(--green); display:flex; align-items:center; gap:4px; }
.ai-status .dot { width:5px; height:5px; background:var(--green-light); border-radius:50%; }
.ai-msg { display:flex; gap:10px; margin-bottom:14px; animation:msgAppear .5s ease; }
@keyframes msgAppear { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
.ai-msg.user { flex-direction:row-reverse; }
.ai-bubble {
  padding:12px 16px; border-radius:14px; max-width:80%; font-size:.85rem; line-height:1.5;
}
.ai-bubble.bot { background:var(--gray-50); border:1px solid var(--gray-200); border-bottom-left-radius:4px; }
.ai-bubble.human { background:var(--green); color:white; border-bottom-right-radius:4px; }
.ai-typing { display:flex; gap:4px; padding:12px 16px; }
.ai-typing span { width:6px; height:6px; background:var(--gray-400); border-radius:50%; animation:typingDot 1.4s infinite; }
.ai-typing span:nth-child(2) { animation-delay:.2s; }
.ai-typing span:nth-child(3) { animation-delay:.4s; }
@keyframes typingDot { 0%,100%{opacity:.3;transform:translateY(0)} 50%{opacity:1;transform:translateY(-4px)} }
@media(max-width:768px) { .ai-grid { grid-template-columns:1fr; gap:32px; } }

/* ═══════════════ IOT DRYER VISUALIZATION ═══════════════ */
.iot-section { background:white; }
.iot-grid { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
.iot-visual {
  background:var(--gray-50); border-radius:var(--radius-lg); padding:32px;
  border:1px solid var(--gray-200); position:relative;
}
.iot-dryer-svg { width:100%; max-width:300px; margin:0 auto 24px; display:block; }
.iot-gauges { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; }
.iot-gauge {
  background:white; border-radius:var(--radius-sm); padding:16px; text-align:center;
  border:1px solid var(--gray-200);
}
.iot-gauge-val { font-family:'Playfair Display',serif; font-size:1.5rem; font-weight:800; }
.iot-gauge-val.green { color:var(--green); }
.iot-gauge-val.gold { color:var(--gold-dark); }
.iot-gauge-val.blue { color:#1565C0; }
.iot-gauge-lbl { font-size:.68rem; color:var(--gray-500); text-transform:uppercase; letter-spacing:.05em; margin-top:4px; }
.iot-gauge-bar { height:4px; background:var(--gray-200); border-radius:2px; margin-top:8px; overflow:hidden; }
.iot-gauge-fill { height:100%; border-radius:2px; transition:width 1.5s ease; }
