<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AGRICHAIN 360™ — Uganda's Complete Post-Harvest Platform</title>
<meta name="description" content="AGRICHAIN 360 connects farmers, buyers, and service providers with verified quality, real-time IoT monitoring, and digital traceability.">
<meta name="theme-color" content="#2E7D32">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
:root{--g:#2E7D32;--g2:#4CAF50;--gd:#1B5E20;--gl:#E8F5E9;--a:#FBC02D;--ad:#F57F17;--bg:#f5f7f5;--bg2:#eef2ee;--card:#fff;--tx:#1a1a1a;--tx2:#666;--tx3:#999;--bd:#e0e0e0;--sh:0 4px 20px rgba(0,0,0,.06);--shl:0 12px 40px rgba(0,0,0,.1)}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--tx);overflow-x:hidden;line-height:1.6}
h1,h2,h3,h4{font-family:'Space Grotesk','Inter',sans-serif;letter-spacing:-.02em;line-height:1.2}
a{color:var(--g);text-decoration:none;transition:color .2s}
a:hover{color:var(--gd)}
img{max-width:100%;height:auto}
.container{max-width:1200px;margin:0 auto;padding:0 20px}

/* ─── PAGE LOADER ─── */
.page-loader{position:fixed;top:0;left:0;right:0;bottom:0;background:white;z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;transition:opacity .6s,visibility .6s}
.page-loader.done{opacity:0;visibility:hidden;pointer-events:none}
.loader-spinner{width:48px;height:48px;border:3px solid var(--bd);border-top-color:var(--g);border-radius:50%;animation:spin .8s linear infinite}
.loader-text{font-weight:600;color:var(--g);font-size:.9rem}
@keyframes spin{to{transform:rotate(360deg)}}

/* ─── ANIMATIONS ─── */
.reveal{opacity:0;transform:translateY(40px);transition:opacity .8s cubic-bezier(.25,.8,.25,1),transform .8s cubic-bezier(.25,.8,.25,1)}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-left{opacity:0;transform:translateX(-40px);transition:opacity .8s ease,transform .8s ease}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(40px);transition:opacity .8s ease,transform .8s ease}
.reveal-right.visible{opacity:1;transform:translateX(0)}
.reveal-scale{opacity:0;transform:scale(.92);transition:opacity .7s ease,transform .7s ease}
.reveal-scale.visible{opacity:1;transform:scale(1)}
.delay-1{transition-delay:.15s!important}
.delay-2{transition-delay:.3s!important}
.delay-3{transition-delay:.45s!important}
.delay-4{transition-delay:.6s!important}
.delay-5{transition-delay:.75s!important}

/* ─── NAVBAR ─── */
.navbar{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,0,0,.06);transition:all .3s;padding:0}
.navbar.scrolled{box-shadow:0 2px 20px rgba(0,0,0,.08)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:64px;max-width:1200px;margin:0 auto;padding:0 20px}
.nav-brand{font-family:'Space Grotesk',sans-serif;font-weight:800;font-size:1.25rem;color:var(--g);display:flex;align-items:center;gap:6px}
.nav-brand sup{font-size:.5rem;vertical-align:super}
.nav-links{display:flex;align-items:center;gap:8px}
.nav-link{padding:8px 16px;border-radius:50px;font-weight:500;font-size:.85rem;color:var(--tx2);transition:all .2s}
.nav-link:hover{color:var(--g);background:var(--gl)}
.nav-cta{padding:8px 20px;border-radius:50px;font-weight:700;font-size:.85rem;border:none;cursor:pointer;transition:all .3s}
.nav-cta-outline{background:transparent;border:2px solid var(--bd);color:var(--tx)}
.nav-cta-outline:hover{border-color:var(--g);color:var(--g)}
.nav-cta-fill{background:var(--g);color:white;box-shadow:0 4px 16px rgba(46,125,50,.25)}
.nav-cta-fill:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(46,125,50,.35);color:white}
.nav-mobile-btn{display:none;background:none;border:none;font-size:1.4rem;color:var(--tx);cursor:pointer;padding:8px}
@media(max-width:768px){
  .nav-links .nav-link{display:none}
  .nav-mobile-btn{display:block}
}

/* Mobile Nav Drawer */
.mobile-nav{position:fixed;top:0;right:-100%;width:280px;height:100vh;background:white;z-index:2000;box-shadow:-4px 0 30px rgba(0,0,0,.15);transition:right .35s cubic-bezier(.25,.8,.25,1);padding:24px;display:flex;flex-direction:column;gap:8px}
.mobile-nav.open{right:0}
.mobile-nav-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:1999;opacity:0;visibility:hidden;transition:all .3s}
.mobile-nav-overlay.open{opacity:1;visibility:visible}
.mobile-nav-close{align-self:flex-end;background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--tx2);padding:4px}
.mobile-nav a{display:block;padding:14px 16px;border-radius:12px;font-weight:600;font-size:1rem;color:var(--tx);transition:background .2s}
.mobile-nav a:hover{background:var(--gl);color:var(--g)}

/* ─── HERO ─── */
.hero{position:relative;background:linear-gradient(135deg,#0d3b0f 0%,#1B5E20 30%,#2E7D32 60%,#388E3C 100%);color:white;padding:120px 0 80px;overflow:hidden}
.hero::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;position:relative;z-index:2}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.15);padding:6px 16px;border-radius:50px;font-size:.8rem;margin-bottom:20px;backdrop-filter:blur(8px)}
.hero-title{font-size:3.2rem;font-weight:900;line-height:1.08;margin-bottom:20px}
.hero-title span{color:var(--a)}
.hero-sub{font-size:1.1rem;opacity:.85;max-width:520px;line-height:1.7;margin-bottom:32px}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap}
.hero-btn{padding:14px 32px;border-radius:50px;font-weight:700;font-size:1rem;border:none;cursor:pointer;transition:all .3s;display:inline-flex;align-items:center;gap:8px;text-decoration:none}
.hero-btn-gold{background:var(--a);color:#3e2723;box-shadow:0 4px 20px rgba(251,192,45,.35)}
.hero-btn-gold:hover{transform:translateY(-3px);box-shadow:0 8px 30px rgba(251,192,45,.45);color:#3e2723}
.hero-btn-white{background:rgba(255,255,255,.12);color:white;border:2px solid rgba(255,255,255,.25);backdrop-filter:blur(8px)}
.hero-btn-white:hover{background:rgba(255,255,255,.2);border-color:rgba(255,255,255,.4);color:white}
.hero-image{position:relative}
.hero-image img{border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,.3);width:100%;object-fit:cover;max-height:420px}
.hero-image::after{content:'';position:absolute;top:-20px;right:-20px;width:100px;height:100px;background:var(--a);border-radius:50%;opacity:.15;animation:float 4s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-15px)}}
.hero-stats{display:flex;gap:24px;margin-top:32px;padding-top:24px;border-top:1px solid rgba(255,255,255,.15)}
.hero-stat-val{font-size:1.6rem;font-weight:900;font-family:'Space Grotesk',sans-serif}
.hero-stat-lbl{font-size:.75rem;opacity:.7;margin-top:2px}
@media(max-width:900px){
  .hero{padding:100px 0 60px}
  .hero-grid{grid-template-columns:1fr;text-align:center}
  .hero-title{font-size:2.2rem}
  .hero-sub{margin-left:auto;margin-right:auto;font-size:1rem}
  .hero-btns{justify-content:center}
  .hero-stats{justify-content:center}
  .hero-image{display:none}
}
@media(max-width:480px){
  .hero{padding:90px 0 50px}
  .hero-title{font-size:1.7rem}
  .hero-btn{padding:12px 24px;font-size:.9rem}
  .hero-stats{gap:16px;flex-wrap:wrap}
  .hero-stat-val{font-size:1.3rem}
}

/* ─── TICKER ─── */
.ticker{max-width:1000px;margin:-40px auto 0;position:relative;z-index:10;padding:0 20px}
.ticker-card{background:white;border-radius:20px;padding:28px 32px;box-shadow:0 8px 40px rgba(0,0,0,.08);border:1px solid rgba(46,125,50,.1)}
.ticker-header{text-align:center;margin-bottom:20px}
.ticker-header h4{font-weight:700;color:var(--g);font-size:1rem}
.ticker-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;text-align:center}
.ticker-val{font-size:1.8rem;font-weight:900;font-family:'Space Grotesk',sans-serif}
.ticker-lbl{font-size:.78rem;color:var(--tx2);margin-top:4px}
.ticker-chg{font-size:.72rem;color:var(--g);margin-top:2px;font-weight:600}
@media(max-width:768px){.ticker-grid{grid-template-columns:repeat(2,1fr);gap:16px}.ticker-val{font-size:1.4rem}}
@media(max-width:480px){.ticker-card{padding:20px 16px}.ticker-val{font-size:1.2rem}}

/* ─── SECTIONS ─── */
.section{padding:80px 0}
.section-sm{padding:50px 0}
.section-title{font-weight:800;font-size:2rem;text-align:center;margin-bottom:12px}
.section-sub{text-align:center;color:var(--tx2);margin-bottom:48px;font-size:1rem;max-width:600px;margin-left:auto;margin-right:auto;line-height:1.6}
@media(max-width:768px){.section{padding:50px 0}.section-title{font-size:1.5rem}}

/* ─── STEPS ─── */
.steps-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative}
.steps-grid::before{content:'';position:absolute;top:40px;left:12.5%;right:12.5%;height:3px;background:linear-gradient(90deg,var(--g),var(--a),var(--g2),var(--ad));border-radius:3px;z-index:0}
.step{text-align:center;position:relative;z-index:1}
.step-num{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:1.1rem;margin:0 auto 16px;box-shadow:0 4px 16px rgba(0,0,0,.15)}
.step-icon{font-size:2rem;margin-bottom:10px}
.step-title{font-weight:700;font-size:.95rem;margin-bottom:6px}
.step-desc{font-size:.82rem;color:var(--tx2);line-height:1.5}
@media(max-width:768px){
  .steps-grid{grid-template-columns:repeat(2,1fr);gap:20px}
  .steps-grid::before{display:none}
}
@media(max-width:480px){.steps-grid{grid-template-columns:1fr}}

/* ─── FEATURES ─── */
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.feature{background:white;border-radius:20px;padding:32px;border:1px solid var(--bd);text-align:center;transition:all .35s cubic-bezier(.25,.8,.25,1)}
.feature:hover{transform:translateY(-8px);box-shadow:0 16px 48px rgba(0,0,0,.1);border-color:var(--g)}
.feature-icon{font-size:2.5rem;margin-bottom:16px}
.feature h4{font-weight:700;margin-bottom:10px;font-size:1.05rem}
.feature p{font-size:.88rem;color:var(--tx2);line-height:1.6;margin-bottom:16px}
.feature-link{display:inline-flex;align-items:center;gap:6px;font-weight:700;font-size:.85rem;padding:8px 20px;border-radius:50px;transition:all .3s}
.feature-link-green{background:var(--gl);color:var(--g)}
.feature-link-green:hover{background:var(--g);color:white}
.feature-link-purple{background:rgba(156,39,176,.1);color:#7B1FA2}
.feature-link-purple:hover{background:#7B1FA2;color:white}
@media(max-width:900px){.features-grid{grid-template-columns:1fr}}

/* ─── IMAGE SECTIONS ─── */
.split{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
.split-reverse{direction:rtl}.split-reverse > *{direction:ltr}
.split-img{border-radius:20px;overflow:hidden;box-shadow:var(--shl);position:relative}
.split-img img{width:100%;height:350px;object-fit:cover;transition:transform .5s ease}
.split-img:hover img{transform:scale(1.05)}
.split-content h3{font-weight:800;font-size:1.6rem;margin-bottom:16px}
.split-content p{color:var(--tx2);line-height:1.7;margin-bottom:20px}
.split-list{list-style:none;padding:0}
.split-list li{display:flex;align-items:flex-start;gap:10px;padding:8px 0;font-size:.9rem;color:var(--tx)}
.split-list li i{color:var(--g);margin-top:3px;flex-shrink:0}
@media(max-width:768px){
  .split{grid-template-columns:1fr;gap:24px}
  .split-reverse{direction:ltr}
  .split-img img{height:250px}
  .split-content h3{font-size:1.3rem}
}

/* ─── TRUST / INVESTOR SECTION ─── */
.trust-section{background:linear-gradient(135deg,#0d3b0f,#1B5E20);color:white;padding:80px 0;position:relative;overflow:hidden}
.trust-section::before{content:'';position:absolute;top:-50%;right:-20%;width:600px;height:600px;background:radial-gradient(circle,rgba(251,192,45,.1),transparent 70%);border-radius:50%}
.trust-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.trust-card{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:28px;backdrop-filter:blur(8px);transition:all .3s}
.trust-card:hover{background:rgba(255,255,255,.12);transform:translateY(-4px)}
.trust-card-icon{font-size:2rem;margin-bottom:14px}
.trust-card h4{font-weight:700;margin-bottom:8px;font-size:1rem}
.trust-card p{font-size:.85rem;opacity:.8;line-height:1.6}
@media(max-width:768px){.trust-grid{grid-template-columns:1fr}}

/* ─── STATS ─── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.stat{background:white;border-radius:16px;padding:24px;text-align:center;border:1px solid var(--bd);transition:all .3s}
.stat:hover{transform:translateY(-4px);box-shadow:var(--shl)}
.stat-icon{font-size:1.5rem;margin-bottom:10px}
.stat-val{font-size:2rem;font-weight:900;font-family:'Space Grotesk',sans-serif}
.stat-lbl{font-size:.85rem;color:var(--tx2);margin-top:4px}
@media(max-width:768px){.stats-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.stats-grid{grid-template-columns:1fr}.stat-val{font-size:1.6rem}}

/* ─── CROPS ─── */
.crops-row{display:flex;justify-content:center;gap:16px;flex-wrap:wrap}
.crop{display:flex;flex-direction:column;align-items:center;background:white;border:1px solid var(--bd);border-radius:14px;padding:20px 24px;width:130px;transition:all .3s}
.crop:hover{transform:translateY(-6px);box-shadow:var(--shl);border-color:var(--g)}
.crop-emoji{font-size:2.2rem;margin-bottom:8px}
.crop-name{font-weight:700;font-size:.9rem}
.crop-sub{font-size:.7rem;color:var(--tx2);margin-top:2px}

/* ─── CTA ─── */
.cta{background:linear-gradient(135deg,#2E7D32,#1B5E20);color:white;padding:80px 0;text-align:center;position:relative;overflow:hidden}
.cta::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M20 20h20v20H20z'/%3E%3C/g%3E%3C/svg%3E")}
.cta h2{font-size:2rem;font-weight:800;margin-bottom:12px;position:relative}
.cta p{opacity:.9;font-size:1.05rem;margin-bottom:32px;position:relative}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;position:relative}
@media(max-width:768px){.cta h2{font-size:1.5rem}.cta p{font-size:.95rem}}

/* ─── FOOTER ─── */
.footer{background:#0a0f0a;color:#ccc;padding:60px 0 24px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px}
.footer h5{color:white;font-weight:700;margin-bottom:16px;font-size:.95rem}
.footer p{font-size:.85rem;line-height:1.7;opacity:.7}
.footer-links{list-style:none;padding:0}
.footer-links li{margin-bottom:8px}
.footer-links a{color:#aaa;font-size:.85rem;transition:color .2s}
.footer-links a:hover{color:var(--a)}
.footer-bottom{border-top:1px solid rgba(255,255,255,.08);padding-top:20px;display:flex;justify-content:space-between;align-items:center;font-size:.8rem;color:#666;flex-wrap:wrap;gap:12px}
@media(max-width:768px){.footer-grid{grid-template-columns:1fr 1fr;gap:24px}}
@media(max-width:480px){.footer-grid{grid-template-columns:1fr}}
</style>
</head>
<body>

<!-- Page Loader -->
<div class="page-loader" id="pageLoader">
  <div class="loader-spinner"></div>
  <div class="loader-text">🌾 AGRICHAIN 360™</div>
</div>

<!-- Mobile Nav -->
<div class="mobile-nav-overlay" id="mobileOverlay" onclick="closeMobileNav()"></div>
<div class="mobile-nav" id="mobileNav">
  <button class="mobile-nav-close" onclick="closeMobileNav()"><i class="fas fa-times"></i></button>
  <a href="/marketplace"><i class="fas fa-store" style="width:24px"></i> Marketplace</a>
  <a href="/ai-advisor"><i class="fas fa-brain" style="width:24px"></i> AI Advisor</a>
  <a href="/iot-dryer"><i class="fas fa-solar-panel" style="width:24px"></i> IoT Monitoring</a>
  <a href="/roles"><i class="fas fa-users" style="width:24px"></i> Get Started</a>
  <a href="/login"><i class="fas fa-sign-in-alt" style="width:24px"></i> Login</a>
  <a href="/signup" style="background:var(--g);color:white;text-align:center;border-radius:12px;margin-top:8px"><i class="fas fa-user-plus" style="width:24px"></i> Create Account</a>
</div>

<!-- Navbar -->
<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a class="nav-brand" href="/">🌾 AGRICHAIN <span style="color:var(--a)">360</span><sup>™</sup></a>
    <div class="nav-links">
      <a href="/marketplace" class="nav-link">Marketplace</a>
      <a href="/ai-advisor" class="nav-link">AI Advisor</a>
      <a href="/iot-dryer" class="nav-link">IoT Monitoring</a>
      <a href="/roles" class="nav-link">Get Started</a>
      <a href="/login" class="nav-cta nav-cta-outline">Login</a>
      <a href="/signup" class="nav-cta nav-cta-fill">Sign Up Free</a>
    </div>
    <button class="nav-mobile-btn" onclick="openMobileNav()"><i class="fas fa-bars"></i></button>
  </div>
</nav>

<!-- ═══════════ HERO ═══════════ -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="hero-badge reveal"><i class="fas fa-award"></i> Uganda's Leading Post-Harvest Platform</div>
        <h1 class="hero-title reveal delay-1">The Complete<br>Post-Harvest <span>Platform</span> for Uganda</h1>
        <p class="hero-sub reveal delay-2">Connect <strong>farmers</strong>, <strong>buyers</strong>, cooperatives and service providers with <strong style="color:var(--a)">verified quality</strong>, real-time <strong style="color:var(--a)">IoT monitoring</strong>, and <strong style="color:var(--a)">digital traceability</strong>.</p>
        <div class="hero-btns reveal delay-3">
          <a href="/marketplace" class="hero-btn hero-btn-gold"><i class="fas fa-store"></i> Browse Marketplace</a>
          <a href="/roles" class="hero-btn hero-btn-white"><i class="fas fa-rocket"></i> Get Started Free</a>
        </div>
        <div class="hero-stats reveal delay-4">
          <div><div class="hero-stat-val">847</div><div class="hero-stat-lbl">Active Farmers</div></div>
          <div><div class="hero-stat-val">42.8T</div><div class="hero-stat-lbl">Tons Dried</div></div>
          <div><div class="hero-stat-val">15.6M</div><div class="hero-stat-lbl">UGX Traded</div></div>
          <div><div class="hero-stat-val">38%</div><div class="hero-stat-lbl">Loss Reduced</div></div>
        </div>
      </div>
      <div class="hero-image reveal-right delay-2">
        <img src="/images/hero-farmers.jpg" alt="Ugandan farmers harvesting maize" loading="eager">
      </div>
    </div>
  </div>
</section>

<!-- ═══════════ IMPACT TICKER ═══════════ -->
<div class="ticker reveal-scale">
  <div class="ticker-card">
