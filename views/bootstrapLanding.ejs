<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AGRICHAIN 360™ — Uganda's Complete Post-Harvest Platform</title>
<meta name="description" content="AGRICHAIN 360 connects farmers, buyers, and service providers with verified quality, real-time IoT monitoring, and digital traceability.">
<meta name="theme-color" content="#1B5E20">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
:root{
  /* 3-COLOR PALETTE: Deep Green + Gold + Charcoal */
  --g:#1B5E20;--g2:#2E7D32;--gd:#0d3b0f;--gl:rgba(27,94,32,.08);
  --a:#D4AF37;--ad:#B8960C;
  --bg:#FAFAF5;--bg2:#F2F0E8;
  --card:#fff;--tx:#333333;--tx2:#666;--tx3:#999;
  --bd:rgba(27,94,32,.12);
  --sh:0 4px 20px rgba(27,94,32,.06);
  --shl:0 12px 40px rgba(27,94,32,.12);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--tx);overflow-x:hidden;line-height:1.6;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4{font-family:'Space Grotesk','Inter',sans-serif;letter-spacing:-.02em;line-height:1.15}
a{color:var(--g);text-decoration:none;transition:color .2s}
a:hover{color:var(--gd)}
img{max-width:100%;height:auto;display:block}
.container{max-width:1200px;margin:0 auto;padding:0 20px}

/* ─── PAGE LOADER ─── */
.page-loader{position:fixed;top:0;left:0;right:0;bottom:0;background:white;z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;transition:opacity .6s,visibility .6s}
.page-loader.done{opacity:0;visibility:hidden;pointer-events:none}
.loader-spinner{width:48px;height:48px;border:3px solid var(--bd);border-top-color:var(--g);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* ─── ANIMATIONS ─── */
.reveal{opacity:0;transform:translateY(40px);transition:opacity .8s cubic-bezier(.25,.8,.25,1),transform .8s cubic-bezier(.25,.8,.25,1)}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-left{opacity:0;transform:translateX(-40px);transition:opacity .8s ease,transform .8s ease}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(40px);transition:opacity .8s ease,transform .8s ease}
.reveal-right.visible{opacity:1;transform:translateX(0)}
.reveal-scale{opacity:0;transform:scale(.92);transition:opacity .7s ease,transform .7s ease}
.reveal-scale.visible{opacity:1;transform:scale(1)}
.d1{transition-delay:.1s!important}.d2{transition-delay:.2s!important}.d3{transition-delay:.3s!important}.d4{transition-delay:.4s!important}.d5{transition-delay:.5s!important}.d6{transition-delay:.6s!important}

/* ─── NAVBAR ─── */
.navbar{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,0,0,.06);transition:all .3s}
.navbar.scrolled{box-shadow:0 2px 20px rgba(0,0,0,.08)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:64px;max-width:1200px;margin:0 auto;padding:0 20px;gap:12px}
.nav-brand{font-family:'Space Grotesk',sans-serif;font-weight:800;font-size:1.15rem;color:var(--g);display:flex;align-items:center;gap:4px;white-space:nowrap;flex-shrink:0}
.nav-brand sup{font-size:.45rem}
.nav-brand .brand-360{color:var(--a)}
.nav-links{display:flex;align-items:center;gap:6px}
.nav-link{padding:8px 14px;border-radius:50px;font-weight:500;font-size:.82rem;color:var(--tx2);transition:all .2s}
.nav-link:hover{color:var(--g);background:var(--gl)}
.nav-cta{padding:8px 20px;border-radius:50px;font-weight:700;font-size:.82rem;border:none;cursor:pointer;transition:all .3s;display:inline-block}
.nav-cta-o{background:transparent;border:2px solid var(--bd);color:var(--tx)}
.nav-cta-o:hover{border-color:var(--g);color:var(--g)}
.nav-cta-f{background:var(--g);color:white;box-shadow:0 4px 16px rgba(27,94,32,.25)}
.nav-cta-f:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(27,94,32,.35);color:white}
.nav-mob{display:none;background:none;border:none;font-size:1.4rem;color:var(--tx);cursor:pointer;flex-shrink:0}
@media(max-width:900px){
  .nav-links .nav-link{display:none}
  .nav-mob{display:block}
  .nav-cta{padding:6px 14px!important;font-size:.75rem!important}
}
@media(max-width:480px){
  .brand-360,.nav-brand sup{display:none}
  .nav-brand{font-size:1rem}
  .nav-inner{gap:8px}
  .nav-cta-o{display:none!important}
}

/* Mobile Nav */
.mob-nav{position:fixed;top:0;right:-100%;width:280px;height:100vh;background:white;z-index:2000;box-shadow:-4px 0 30px rgba(0,0,0,.15);transition:right .35s;padding:24px;display:flex;flex-direction:column;gap:6px}
.mob-nav.open{right:0}
.mob-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:1999;opacity:0;visibility:hidden;transition:all .3s}
.mob-overlay.open{opacity:1;visibility:visible}
.mob-close{align-self:flex-end;background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--tx2);margin-bottom:12px}
.mob-nav a{display:block;padding:14px 16px;border-radius:12px;font-weight:600;color:var(--tx);transition:background .2s}
.mob-nav a:hover{background:var(--gl);color:var(--g)}

/* ─── HERO ─── */
.hero{position:relative;background:linear-gradient(135deg,#0d3b0f 0%,#1B5E20 30%,#2E7D32 60%,#388E3C 100%);color:white;padding:120px 0 100px;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E")}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;position:relative;z-index:2}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.15);padding:6px 16px;border-radius:50px;font-size:.78rem;margin-bottom:20px;backdrop-filter:blur(8px)}
.hero-title{font-size:3rem;font-weight:900;line-height:1.08;margin-bottom:20px}
.hero-title span{color:var(--a)}
.hero-sub{font-size:1.05rem;opacity:.85;max-width:500px;line-height:1.7;margin-bottom:28px}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:32px}
.hero-btn{padding:14px 28px;border-radius:50px;font-weight:700;font-size:.95rem;border:none;cursor:pointer;transition:all .3s;display:inline-flex;align-items:center;gap:8px;text-decoration:none}
.hero-btn-gold{background:var(--a);color:#3e2723;box-shadow:0 4px 20px rgba(212,175,55,.35)}
.hero-btn-gold:hover{transform:translateY(-3px);box-shadow:0 8px 30px rgba(212,175,55,.45);color:#3e2723}
.hero-btn-glass{background:rgba(255,255,255,.12);color:white;border:2px solid rgba(255,255,255,.25);backdrop-filter:blur(8px)}
.hero-btn-glass:hover{background:rgba(255,255,255,.2);border-color:rgba(255,255,255,.4);color:white}

/* Hero Stats — BOLD & CLEAR */
.hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;padding:20px;background:rgba(255,255,255,.1);border-radius:16px;border:1px solid rgba(255,255,255,.15);backdrop-filter:blur(12px)}
.hero-stat{text-align:center}
.hero-stat-val{font-size:1.8rem;font-weight:900;font-family:'Space Grotesk',sans-serif;display:block;line-height:1}
.hero-stat-lbl{font-size:.72rem;opacity:.75;margin-top:6px;display:block;text-transform:uppercase;letter-spacing:.05em}
.hero-stat:nth-child(1) .hero-stat-val{color:#fff}
.hero-stat:nth-child(2) .hero-stat-val{color:var(--a)}
.hero-stat:nth-child(3) .hero-stat-val{color:#2E7D32}
.hero-stat:nth-child(4) .hero-stat-val{color:#D4AF37}

/* Hero Image */
.hero-img{position:relative}
.hero-img img{border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,.3);width:100%;height:420px;object-fit:cover}
.hero-img::after{content:'';position:absolute;top:-20px;right:-20px;width:100px;height:100px;background:var(--a);border-radius:50%;opacity:.15;animation:float 4s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-15px)}}

@media(max-width:900px){
  .hero{padding:100px 0 60px}
  .hero-grid{grid-template-columns:1fr;text-align:center}
  .hero-title{font-size:2rem}
  .hero-sub{margin:0 auto 24px;font-size:.95rem}
  .hero-btns{justify-content:center}
  .hero-stats{grid-template-columns:repeat(2,1fr);gap:12px;padding:16px}
  .hero-stat-val{font-size:1.4rem}
  .hero-img{display:none}
}
@media(max-width:480px){
  .hero-title{font-size:1.6rem}
  .hero-btn{padding:12px 20px;font-size:.85rem}
  .hero-stats{grid-template-columns:repeat(2,1fr)}
  .hero-stat-val{font-size:1.2rem}
}

/* ─── SECTIONS ─── */
.section{padding:80px 0}
.section-sm{padding:50px 0}
.section-title{font-weight:800;font-size:2rem;text-align:center;margin-bottom:12px}
.section-sub{text-align:center;color:var(--tx2);margin-bottom:48px;font-size:1rem;max-width:600px;margin-left:auto;margin-right:auto;line-height:1.7}
@media(max-width:768px){.section{padding:50px 0}.section-title{font-size:1.4rem}.section-sub{font-size:.9rem;margin-bottom:32px}}

/* ─── PROBLEM SECTION ─── */
.problem{background:linear-gradient(135deg,#1a1a2e,#16213e);color:white;padding:80px 0;position:relative;overflow:hidden}
.problem::before{content:'';position:absolute;top:0;right:0;width:50%;height:100%;background:url('/images/post-harvest-problem.jpg') center/cover;opacity:.15}
.problem-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;position:relative;z-index:2}
.problem h2{font-size:2rem;font-weight:800;margin-bottom:16px;color:white}
.problem h2 span{color:#D4AF37}
.problem p{opacity:.85;line-height:1.7;margin-bottom:16px;font-size:.95rem}
.problem-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:24px}
.problem-stat{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:20px;text-align:center}
.problem-stat-val{font-size:1.6rem;font-weight:900;color:#D4AF37;font-family:'Space Grotesk',sans-serif}
.problem-stat-lbl{font-size:.75rem;opacity:.7;margin-top:4px}
.problem-img{border-radius:20px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.4)}
.problem-img img{width:100%;height:350px;object-fit:cover}
@media(max-width:768px){
  .problem-grid{grid-template-columns:1fr}
  .problem h2{font-size:1.5rem}
  .problem-stats{grid-template-columns:1fr 1fr 1fr;gap:10px}
  .problem-stat{padding:14px}
  .problem-stat-val{font-size:1.2rem}
  .problem-img img{height:220px}
}

/* ─── STEPS ─── */
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative}
.steps::before{content:'';position:absolute;top:36px;left:12%;right:12%;height:3px;background:linear-gradient(90deg,var(--g),var(--a),var(--g2),var(--ad));border-radius:3px;z-index:0}
.step{text-align:center;position:relative;z-index:1}
.step-n{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:800;margin:0 auto 14px;box-shadow:0 4px 16px rgba(0,0,0,.15)}
.step-ico{font-size:2rem;margin-bottom:8px}
.step-t{font-weight:700;font-size:.9rem;margin-bottom:4px}
.step-d{font-size:.78rem;color:var(--tx2);line-height:1.5}
@media(max-width:768px){.steps{grid-template-columns:repeat(2,1fr)}.steps::before{display:none}}
@media(max-width:480px){.steps{grid-template-columns:1fr}}

/* ─── FEATURES ─── */
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.feat{background:white;border-radius:20px;padding:32px;border:1px solid var(--bd);text-align:center;transition:all .35s cubic-bezier(.25,.8,.25,1)}
.feat:hover{transform:translateY(-8px);box-shadow:0 16px 48px rgba(0,0,0,.1);border-color:var(--g)}
.feat-ico{font-size:2.5rem;margin-bottom:14px}
.feat h4{font-weight:700;margin-bottom:8px;font-size:1rem}
.feat p{font-size:.85rem;color:var(--tx2);line-height:1.6;margin-bottom:16px}
.feat-link{display:inline-flex;align-items:center;gap:6px;font-weight:700;font-size:.82rem;padding:8px 20px;border-radius:50px;transition:all .3s}
.feat-link-g{background:var(--gl);color:var(--g)}.feat-link-g:hover{background:var(--g);color:white}
.feat-link-p{background:rgba(156,39,176,.1);color:#7B1FA2}.feat-link-p:hover{background:#7B1FA2;color:white}
@media(max-width:900px){.feat-grid{grid-template-columns:1fr}}

/* ─── SPLIT ─── */
.split{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
.split-rev{direction:rtl}.split-rev>*{direction:ltr}
.split-img{border-radius:20px;overflow:hidden;box-shadow:var(--shl)}
.split-img img{width:100%;height:340px;object-fit:cover;transition:transform .5s}
.split-img:hover img{transform:scale(1.05)}
.split-c h3{font-weight:800;font-size:1.5rem;margin-bottom:14px}
.split-c p{color:var(--tx2);line-height:1.7;margin-bottom:16px;font-size:.92rem}
.split-list{list-style:none;padding:0}
.split-list li{display:flex;align-items:flex-start;gap:10px;padding:6px 0;font-size:.88rem}
.split-list li i{color:var(--g);margin-top:3px;flex-shrink:0}
@media(max-width:768px){.split{grid-template-columns:1fr;gap:24px}.split-rev{direction:ltr}.split-img img{height:220px}.split-c h3{font-size:1.2rem}}

/* ─── INVESTOR SECTION ─── */
.investor{background:linear-gradient(135deg,#0d3b0f,#1B5E20);color:white;padding:80px 0;position:relative;overflow:hidden}
.investor::before{content:'';position:absolute;top:-50%;right:-20%;width:600px;height:600px;background:radial-gradient(circle,rgba(212,175,55,.1),transparent 70%);border-radius:50%}
.investor h2{color:white}
.investor .section-sub{color:rgba(255,255,255,.7)}
.inv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.inv-card{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:28px;backdrop-filter:blur(8px);transition:all .3s}
.inv-card:hover{background:rgba(255,255,255,.12);transform:translateY(-4px)}
.inv-card-ico{font-size:2rem;margin-bottom:12px}
.inv-card h4{font-weight:700;margin-bottom:8px;font-size:1rem}
.inv-card p{font-size:.82rem;opacity:.8;line-height:1.6}
.inv-card .inv-metric{margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.1)}
.inv-card .inv-metric-val{font-size:1.3rem;font-weight:900;font-family:'Space Grotesk',sans-serif;color:var(--a)}
.inv-card .inv-metric-lbl{font-size:.72rem;opacity:.6}
@media(max-width:768px){.inv-grid{grid-template-columns:1fr}}

/* ─── NGO SECTION ─── */
.ngo{background:linear-gradient(135deg,#1B5E20,#0d3b0d);color:white;padding:80px 0;position:relative;overflow:hidden}
.ngo::before{content:'';position:absolute;bottom:-30%;left:-10%;width:500px;height:500px;background:radial-gradient(circle,rgba(255,255,255,.08),transparent 70%);border-radius:50%}
.ngo h2{color:white}
.ngo .section-sub{color:rgba(255,255,255,.7)}
.ngo-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;position:relative;z-index:2}
.ngo-img{border-radius:20px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.3)}
.ngo-img img{width:100%;height:380px;object-fit:cover}
.ngo-items{display:flex;flex-direction:column;gap:16px}
.ngo-item{display:flex;gap:14px;align-items:flex-start;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:18px;transition:all .3s}
.ngo-item:hover{background:rgba(255,255,255,.12)}
.ngo-item-ico{width:44px;height:44px;border-radius:12px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0}
.ngo-item h4{font-weight:700;font-size:.92rem;margin-bottom:4px}
.ngo-item p{font-size:.8rem;opacity:.8;line-height:1.5}
@media(max-width:768px){.ngo-grid{grid-template-columns:1fr}.ngo-img img{height:220px}}

/* ─── STATS ─── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.stat{background:white;border-radius:16px;padding:24px;text-align:center;border:1px solid var(--bd);transition:all .3s}
.stat:hover{transform:translateY(-4px);box-shadow:var(--shl)}
.stat-ico{font-size:1.5rem;margin-bottom:8px}
.stat-val{font-size:2rem;font-weight:900;font-family:'Space Grotesk',sans-serif}
.stat-lbl{font-size:.82rem;color:var(--tx2);margin-top:4px}
@media(max-width:768px){.stats-grid{grid-template-columns:repeat(2,1fr)}.stat-val{font-size:1.5rem}}

/* ─── CROPS ─── */
.crops-row{display:flex;justify-content:center;gap:14px;flex-wrap:wrap}
.crop{display:flex;flex-direction:column;align-items:center;background:white;border:1px solid var(--bd);border-radius:14px;padding:18px 22px;width:120px;transition:all .3s}
.crop:hover{transform:translateY(-6px);box-shadow:var(--shl);border-color:var(--g)}
.crop-e{font-size:2rem;margin-bottom:6px}
.crop-n{font-weight:700;font-size:.85rem}
.crop-s{font-size:.68rem;color:var(--tx3);margin-top:2px}

/* ─── CTA ─── */
.cta{background:linear-gradient(135deg,#2E7D32,#1B5E20);color:white;padding:80px 0;text-align:center;position:relative;overflow:hidden}
.cta::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M20 20h20v20H20z'/%3E%3C/g%3E%3C/svg%3E")}
.cta h2{font-size:2rem;font-weight:800;margin-bottom:12px;position:relative}
.cta p{opacity:.9;font-size:1rem;margin-bottom:32px;position:relative}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;position:relative}
@media(max-width:768px){.cta h2{font-size:1.4rem}.cta p{font-size:.9rem}}

/* ─── FOOTER ─── */
.footer{background:#0a0f0a;color:#ccc;padding:60px 0 24px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px}
.footer h5{color:white;font-weight:700;margin-bottom:14px;font-size:.9rem}
.footer p,.footer a{font-size:.82rem;line-height:1.7;opacity:.7}
.footer a{color:#aaa;transition:color .2s}.footer a:hover{color:var(--a);opacity:1}
.footer-links{list-style:none;padding:0}.footer-links li{margin-bottom:6px}
.footer-bottom{border-top:1px solid rgba(255,255,255,.08);padding-top:20px;display:flex;justify-content:space-between;align-items:center;font-size:.78rem;color:#666;flex-wrap:wrap;gap:12px}
@media(max-width:768px){.footer-grid{grid-template-columns:1fr 1fr;gap:20px}}
@media(max-width:480px){.footer-grid{grid-template-columns:1fr}}
</style>
</head>
<body>

<!-- Page Loader -->
<div class="page-loader" id="pageLoader"><div class="loader-spinner"></div></div>

<!-- Mobile Nav -->
<div class="mob-overlay" id="mobOverlay" onclick="closeMob()"></div>
<div class="mob-nav" id="mobNav">
  <button class="mob-close" onclick="closeMob()"><i class="fas fa-times"></i></button>
  <a href="/marketplace"><i class="fas fa-store" style="width:24px"></i> Marketplace</a>
  <a href="/ai-advisor"><i class="fas fa-brain" style="width:24px"></i> AI Advisor</a>
  <a href="/iot-dryer"><i class="fas fa-solar-panel" style="width:24px"></i> IoT Monitoring</a>
