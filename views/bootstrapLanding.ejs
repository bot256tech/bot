<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AGRICHAIN 360™ — The Digital Infrastructure Powering Agriculture Across Africa</title>
<meta name="description" content="AGRICHAIN 360 connects farmers, cooperatives, buyers, transporters, warehouses, exporters, financial institutions, NGOs, and governments through one intelligent digital ecosystem.">
<meta name="theme-color" content="#1B5E20">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
/* ═══════════════════════════════════════════════════════════
   AGRICHAIN 360™ — EDITORIAL DESIGN SYSTEM
   Harvard Business Review × National Geographic
   Deep Green #1B5E20 | Gold #D4AF37 | Cream #FAFAF5 | Charcoal #333
   ═══════════════════════════════════════════════════════════ */
:root {
  --green: #1B5E20; --green-mid: #2E7D32; --green-light: #4CAF50; --green-pale: #E8F5E9;
  --gold: #D4AF37; --gold-light: #F5E6A3; --gold-dark: #B8960C;
  --cream: #FAFAF5; --white: #FFFFFF;
  --charcoal: #333333; --gray-500: #777; --gray-400: #999; --gray-300: #bbb; --gray-200: #ddd; --gray-100: #eee;
  --shadow: 0 4px 20px rgba(0,0,0,.06); --shadow-lg: 0 12px 40px rgba(0,0,0,.1);
  --radius: 12px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
body{font-family:'Inter',system-ui,sans-serif;background:var(--cream);color:var(--charcoal);overflow-x:hidden;line-height:1.7;font-size:16px}
img{max-width:100%;display:block}
a{color:var(--green);text-decoration:none;transition:color .2s}
a:hover{color:var(--green-mid)}

/* Typography */
h1,h2,h3,h4{font-family:'Playfair Display',Georgia,serif;letter-spacing:-.02em;line-height:1.15;color:var(--charcoal)}
.eyebrow{font-family:'Inter',sans-serif;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.15em;color:var(--gold-dark);margin-bottom:12px;display:flex;align-items:center;gap:10px}
.eyebrow::before{content:'';width:32px;height:2px;background:var(--gold);display:inline-block}
.pull-quote{font-family:'Playfair Display',Georgia,serif;font-size:1.4rem;font-style:italic;color:var(--green);line-height:1.4;border-left:3px solid var(--gold);padding-left:20px;margin:32px 0}

/* Scroll animations */
.reveal{opacity:0;transform:translateY(30px);transition:opacity .8s ease,transform .8s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-left{opacity:0;transform:translateX(-30px);transition:opacity .8s ease,transform .8s ease}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(30px);transition:opacity .8s ease,transform .8s ease}
.reveal-right.visible{opacity:1;transform:translateX(0)}
.d1{transition-delay:.1s!important}.d2{transition-delay:.2s!important}.d3{transition-delay:.3s!important}.d4{transition-delay:.4s!important}

/* ═══ NAVBAR — Elegant Fixed ═══ */
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(250,250,245,.95);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(27,94,32,.06);transition:all .3s}
.nav.scrolled{box-shadow:0 1px 12px rgba(0,0,0,.05)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;max-width:1200px;margin:0 auto;padding:0 32px;height:68px}
.nav-brand{font-family:'Playfair Display',serif;font-weight:800;font-size:1.15rem;color:var(--green);text-decoration:none;display:flex;align-items:center;gap:8px}
.nav-brand .dot{width:8px;height:8px;background:var(--gold);border-radius:50%;display:inline-block}
.nav-links{display:flex;align-items:center;gap:4px}
.nav-links a{padding:8px 16px;border-radius:8px;font-size:.85rem;font-weight:500;color:var(--gray-500);text-decoration:none;transition:all .2s}
.nav-links a:hover{color:var(--green);background:var(--green-pale)}
.nav-cta{padding:10px 24px!important;border-radius:10px!important;background:var(--green)!important;color:white!important;font-weight:600!important;box-shadow:0 2px 8px rgba(27,94,32,.15)}
.nav-cta:hover{background:var(--green-mid)!important;transform:translateY(-1px);box-shadow:0 4px 16px rgba(27,94,32,.25)}
.nav-mob{display:none;background:none;border:none;font-size:1.2rem;color:var(--charcoal);cursor:pointer}
@media(max-width:900px){.nav-links a:not(.nav-cta){display:none}.nav-mob{display:block}.nav-inner{padding:0 20px}}

/* Mobile drawer */
.mob-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:1999;opacity:0;visibility:hidden;transition:all .3s}
.mob-overlay.open{opacity:1;visibility:visible}
.mob-drawer{position:fixed;top:0;right:-100%;width:280px;height:100vh;background:white;z-index:2000;box-shadow:-4px 0 30px rgba(0,0,0,.12);transition:right .35s;padding:24px;display:flex;flex-direction:column;gap:4px}
.mob-drawer.open{right:0}
.mob-close{align-self:flex-end;background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--gray-400);margin-bottom:16px}
.mob-drawer a{display:block;padding:14px 16px;border-radius:12px;font-weight:600;color:var(--charcoal);text-decoration:none;transition:background .2s}
.mob-drawer a:hover{background:var(--green-pale);color:var(--green)}

/* ═══ HERO — Full-bleed Cinematic ═══ */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;background:var(--green)}
.hero-bg{position:absolute;inset:0}
.hero-bg img{width:100%;height:100%;object-fit:cover;opacity:.35}
.hero-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(160deg,rgba(13,59,13,.92) 0%,rgba(27,94,32,.85) 40%,rgba(27,94,32,.75) 100%)}
.hero-content{position:relative;z-index:2;max-width:800px;margin:0 auto;padding:140px 32px 100px;text-align:center}
.hero-eyebrow{font-family:'Inter',sans-serif;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;color:var(--gold);margin-bottom:24px;display:inline-flex;align-items:center;gap:10px}
.hero-eyebrow::before,.hero-eyebrow::after{content:'';width:24px;height:1px;background:var(--gold)}
.hero h1{font-size:3.5rem;font-weight:800;color:white;margin-bottom:24px;line-height:1.1}
.hero h1 em{font-style:italic;color:var(--gold);font-weight:500}
.hero-sub{font-size:1.15rem;color:rgba(255,255,255,.8);max-width:600px;margin:0 auto 40px;line-height:1.7;font-weight:300}
.hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
.hero-btn{padding:16px 32px;border-radius:12px;font-weight:600;font-size:.95rem;border:none;cursor:pointer;transition:all .3s;text-decoration:none;display:inline-flex;align-items:center;gap:8px}
.hero-btn-gold{background:var(--gold);color:#3e2723;box-shadow:0 4px 20px rgba(212,175,55,.3)}
.hero-btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(212,175,55,.4);color:#3e2723}
.hero-btn-glass{background:rgba(255,255,255,.1);color:white;border:1px solid rgba(255,255,255,.25);backdrop-filter:blur(8px)}
.hero-btn-glass:hover{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.4);color:white}
.hero-scroll{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.4);font-size:.75rem;text-transform:uppercase;letter-spacing:.15em;display:flex;flex-direction:column;align-items:center;gap:8px;z-index:2}
.hero-scroll .arrow{width:1px;height:32px;background:rgba(255,255,255,.3);position:relative;animation:scrollArrow 2s infinite}
@keyframes scrollArrow{0%{opacity:.3;height:20px}50%{opacity:.8;height:32px}100%{opacity:.3;height:20px}}
@media(max-width:768px){.hero h1{font-size:2.2rem}.hero-sub{font-size:1rem}.hero-content{padding:120px 20px 80px}}
@media(max-width:480px){.hero h1{font-size:1.8rem}.hero-btns{flex-direction:column;align-items:center}.hero-btn{width:100%;justify-content:center}}

/* ═══ SECTION SHARED ═══ */
.section{padding:100px 0;position:relative}
.container{max-width:1100px;margin:0 auto;padding:0 32px}
.section-center{text-align:center}
.gold-rule{width:60px;height:2px;background:var(--gold);margin:0 auto 20px;border-radius:2px}
.gold-rule-left{width:60px;height:2px;background:var(--gold);margin-bottom:20px;border-radius:2px}
@media(max-width:768px){.section{padding:60px 0}.container{padding:0 20px}}

/* ═══ THE PROBLEM — Editorial ═══ */
.problem{background:var(--cream)}
.problem-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.problem h2{font-size:2.4rem;margin-bottom:20px}
.problem h2 em{font-style:italic;color:var(--green)}
.problem-text p{color:var(--gray-500);font-size:1rem;margin-bottom:16px;line-height:1.8}
.problem-stat-row{display:flex;gap:24px;margin-top:32px;padding-top:32px;border-top:1px solid var(--gray-200)}
.problem-stat{text-align:center}
.problem-stat-val{font-family:'Playfair Display',serif;font-size:2.4rem;font-weight:800;color:var(--green);line-height:1}
.problem-stat-val.gold{color:var(--gold-dark)}
.problem-stat-lbl{font-size:.75rem;color:var(--gray-400);margin-top:6px;text-transform:uppercase;letter-spacing:.05em}
.problem-img{border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-lg);position:relative}
.problem-img img{width:100%;height:400px;object-fit:cover}
.problem-img::after{content:'';position:absolute;bottom:0;left:0;right:0;height:60px;background:linear-gradient(to top,rgba(27,94,32,.3),transparent)}
.problem-img-caption{position:absolute;bottom:16px;left:16px;color:white;font-size:.75rem;font-weight:500;text-shadow:0 1px 4px rgba(0,0,0,.5)}
@media(max-width:768px){.problem-grid{grid-template-columns:1fr;gap:32px}.problem h2{font-size:1.8rem}.problem-stat-row{gap:16px}.problem-stat-val{font-size:1.8rem}.problem-img img{height:260px}}

/* ═══ SOLUTION + 4-STEP FLOW ═══ */
.solution{background:white}
.solution h2{font-size:2.2rem;text-align:center;margin-bottom:16px}
.solution-sub{text-align:center;color:var(--gray-500);max-width:600px;margin:0 auto 48px;font-size:1rem}
.steps-row{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative}
.steps-row::before{content:'';position:absolute;top:36px;left:12%;right:12%;height:2px;background:linear-gradient(90deg,var(--green),var(--gold),var(--green-light),var(--gold-dark));border-radius:2px;z-index:0}
.step-card{text-align:center;position:relative;z-index:1}
.step-num{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-family:'Playfair Display',serif;font-weight:800;font-size:1.1rem;color:white;box-shadow:0 4px 12px rgba(0,0,0,.12)}
.step-num.s1{background:var(--green)}.step-num.s2{background:var(--gold);color:#3e2723}.step-num.s3{background:var(--green-light)}.step-num.s4{background:var(--gold-dark);color:white}
.step-icon{font-size:1.8rem;margin-bottom:8px}
.step-title{font-family:'Inter',sans-serif;font-weight:700;font-size:.9rem;margin-bottom:4px}
.step-desc{font-size:.78rem;color:var(--gray-500);line-height:1.5}
@media(max-width:768px){.steps-row{grid-template-columns:repeat(2,1fr);gap:20px}.steps-row::before{display:none}}
@media(max-width:480px){.steps-row{grid-template-columns:1fr}}

/* ═══ VALUE CHAIN TIMELINE ═══ */
.chain{background:var(--cream)}
.chain h2{font-size:2rem;text-align:center;margin-bottom:40px}
.chain-track{display:flex;gap:0;overflow-x:auto;padding:16px 0 32px;scrollbar-width:thin;scrollbar-color:var(--green-pale) transparent}
.chain-track::-webkit-scrollbar{height:4px}
.chain-track::-webkit-scrollbar-thumb{background:var(--green-pale);border-radius:2px}
.chain-node{flex:0 0 140px;text-align:center;position:relative;padding:16px 8px;cursor:pointer;transition:all .3s}
.chain-node:hover{transform:translateY(-4px)}
.chain-node::after{content:'→';position:absolute;right:-6px;top:50%;transform:translateY(-50%);color:var(--gray-300);font-size:1rem;font-weight:300}
.chain-node:last-child::after{display:none}
.chain-ico{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;font-size:1.2rem;background:white;border:2px solid var(--gray-200);transition:all .3s}
.chain-node:hover .chain-ico{border-color:var(--green);background:var(--green-pale)}
.chain-name{font-weight:600;font-size:.78rem}
.chain-sub{font-size:.68rem;color:var(--gray-400);margin-top:2px}

/* ═══ PLATFORM MODULES — 2×4 Cards with Gold Tops ═══ */
.modules{background:white}
.modules h2{font-size:2rem;text-align:center;margin-bottom:16px}
.modules-sub{text-align:center;color:var(--gray-500);max-width:560px;margin:0 auto 48px;font-size:.95rem}
.mod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.mod-card{background:var(--cream);border-radius:var(--radius);padding:28px 20px;text-align:center;border:1px solid var(--gray-200);transition:all .35s;position:relative;overflow:hidden}
.mod-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--gold);transform:scaleX(0);transition:transform .35s;transform-origin:left}
.mod-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg);border-color:var(--green)}
.mod-card:hover::before{transform:scaleX(1)}
.mod-ico{font-size:2rem;margin-bottom:14px;display:block}
.mod-title{font-family:'Inter',sans-serif;font-weight:700;font-size:.9rem;margin-bottom:6px}
.mod-desc{font-size:.78rem;color:var(--gray-500);line-height:1.5}
@media(max-width:900px){.mod-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.mod-grid{grid-template-columns:1fr}}

/* ═══ IMPACT METRICS — Deep Green ═══ */
.impact-bar{background:var(--green);color:white;padding:80px 0;position:relative;overflow:hidden}
.impact-bar::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='30' cy='30' r='1' fill='white' opacity='.05'/%3E%3C/svg%3E")}
.impact-bar .eyebrow{color:var(--gold);justify-content:center}
.impact-bar .eyebrow::before{background:var(--gold)}
.impact-bar h2{color:white;text-align:center;font-size:2rem;margin-bottom:40px}
.impact-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:24px;position:relative;z-index:2}
.impact-item{text-align:center}
.impact-num{font-family:'Playfair Display',serif;font-size:2.6rem;font-weight:900;line-height:1;display:block;margin-bottom:8px}
.impact-num.gold{color:var(--gold)}
.impact-lbl{font-size:.75rem;opacity:.65;text-transform:uppercase;letter-spacing:.08em}
.impact-note{text-align:center;margin-top:32px;font-size:.78rem;opacity:.4;position:relative;z-index:2}
@media(max-width:900px){.impact-grid{grid-template-columns:repeat(3,1fr);gap:20px}.impact-num{font-size:2rem}}
@media(max-width:480px){.impact-grid{grid-template-columns:repeat(2,1fr)}.impact-num{font-size:1.6rem}}

/* ═══ PHOTOGRAPHY GRID ═══ */
.photo-grid{padding:0;overflow:hidden}
.photo-row{display:flex;gap:0;height:240px}
.photo-row img{flex:1;object-fit:cover;height:240px;transition:all .5s}
.photo-row img:hover{filter:brightness(1.08)}
.photo-caption{text-align:center;padding:20px;font-size:.78rem;color:var(--gray-400);letter-spacing:.05em}
@media(max-width:768px){.photo-row{height:160px}.photo-row img{height:160px}}

/* ═══ COMPARISON ═══ */
.compare{background:var(--cream)}
.compare h2{font-size:2rem;text-align:center;margin-bottom:40px}
.compare-table{display:grid;grid-template-columns:1fr auto 1fr;gap:24px;align-items:start}
.compare-col{background:white;border-radius:var(--radius);padding:28px;border:1px solid var(--gray-200)}
.compare-col.new{border-color:var(--green);box-shadow:0 0 0 1px var(--green)}
.compare-header{font-weight:800;font-size:1rem;margin-bottom:16px;display:flex;align-items:center;gap:8px}
.compare-header .badge{padding:4px 12px;border-radius:50px;font-size:.68rem;font-weight:700}
.compare-header .badge.old{background:var(--gray-100);color:var(--gray-500)}
.compare-header .badge.new{background:var(--green-pale);color:var(--green)}
.compare-item{display:flex;align-items:center;gap:8px;padding:10px 0;border-bottom:1px solid var(--gray-100);font-size:.85rem}
.compare-item:last-child{border:none}
.compare-item i{font-size:.75rem;width:18px;text-align:center}
.compare-item i.fa-xmark{color:#c62828}
.compare-item i.fa-check{color:var(--green)}
.compare-vs{display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:800;color:var(--gray-300);padding-top:60px}
@media(max-width:768px){.compare-table{grid-template-columns:1fr}.compare-vs{padding:12px 0}}

/* ═══ TESTIMONIALS ═══ */
.testi{background:white}
.testi h2{font-size:2rem;text-align:center;margin-bottom:40px}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.testi-card{background:var(--cream);border-radius:var(--radius);padding:28px;border:1px solid var(--gray-200);transition:all .3s}
.testi-card:hover{transform:translateY(-4px);box-shadow:var(--shadow)}
.testi-quote{font-size:.9rem;line-height:1.6;color:var(--gray-500);margin-bottom:20px;font-style:italic}
.testi-author{display:flex;align-items:center;gap:12px}
.testi-avatar{width:40px;height:40px;border-radius:50%;background:var(--green-pale);display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--green);font-size:.85rem}
.testi-name{font-weight:700;font-size:.85rem}
.testi-role{font-size:.72rem;color:var(--gray-400)}
@media(max-width:768px){.testi-grid{grid-template-columns:1fr}}

/* ═══ CTA FOOTER ═══ */
.cta-final{background:var(--charcoal);color:white;padding:100px 0;text-align:center;position:relative;overflow:hidden}
.cta-final::before{content:'';position:absolute;top:-50%;left:50%;transform:translateX(-50%);width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(27,94,32,.2),transparent 60%)}
.cta-final h2{color:white;font-size:2.4rem;margin-bottom:16px;position:relative}
.cta-final p{color:rgba(255,255,255,.6);font-size:1.05rem;margin-bottom:40px;position:relative}
.cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;position:relative}
@media(max-width:768px){.cta-final h2{font-size:1.8rem}}

/* ═══ FOOTER ═══ */
.footer{background:#0a0f0a;color:#ccc;padding:60px 0 24px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px}
.footer-brand{font-family:'Playfair Display',serif;font-weight:800;font-size:1rem;color:white;margin-bottom:10px}
.footer-desc{font-size:.8rem;opacity:.5;line-height:1.6;margin-bottom:14px}
.footer h5{color:white;font-family:'Inter',sans-serif;font-weight:700;font-size:.75rem;text-transform:uppercase;letter-spacing:.1em;margin-bottom:14px}
.footer-links{list-style:none}
.footer-links li{margin-bottom:6px}
.footer-links a{color:#888;font-size:.8rem;text-decoration:none;transition:color .2s}
.footer-links a:hover{color:var(--gold)}
.footer-bottom{border-top:1px solid rgba(255,255,255,.06);padding-top:20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;font-size:.75rem;color:#555}
@media(max-width:768px){.footer-grid{grid-template-columns:1fr 1fr;gap:20px}}
@media(max-width:480px){.footer-grid{bold:1fr}}
</style>
</head>
<body>

<!-- ═══ NAVBAR ═══ -->
<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand"><span class="dot"></span> AGRICHAIN 360</a>
    <div class="nav-links">
      <a href="#problem">The Problem</a>
      <a href="#solution">Solution</a>
      <a href="#platform">Platform</a>
      <a href="#impact">Impact</a>
      <a href="/login">Login</a>
      <a href="/signup" class="nav-cta">Get Started</a>
    </div>
    <button class="nav-mob" onclick="openDrawer()"><i class="fas fa-bars"></i></button>
  </div>
</nav>
<div class="mob-overlay" id="mobOverlay" onclick="closeDrawer()"></div>
<div class="mob-drawer" id="mobDrawer">
  <button class="mob-close" onclick="closeDrawer()"><i class="fas fa-times"></i></button>
  <a href="#problem" onclick="closeDrawer()">The Problem</a>
  <a href="#solution" onclick="closeDrawer()">Solution</a>
  <a href="#platform" onclick="closeDrawer()">Platform</a>
  <a href="#impact" onclick="closeDrawer()">Impact</a>
  <a href="/marketplace" onclick="closeDrawer()">Marketplace</a>
  <a href="/ai-advisor" onclick="closeDrawer()">AI Advisor</a>
  <a href="/login" onclick="closeDrawer()">Login</a>
