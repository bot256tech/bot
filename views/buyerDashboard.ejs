<!-- Buyer Dashboard — Shows real user data from session -->
<div style="margin-bottom:24px">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px">
    <div>
      <h2 style="font-weight:800;margin-bottom:4px">
        Welcome, <%= typeof user !== 'undefined' && user ? user.name : 'Buyer' %> 🏢
      </h2>
      <div style="color:var(--tx2);font-size:.9rem">
        Enterprise Buyer Dashboard
        <% if (typeof user !== 'undefined' && user && user.phone) { %>
          • <%= user.phone %>
        <% } %>
      </div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <a href="/marketplace" class="btn btn-p btn-sm"><i class="fas fa-store"></i> Browse Marketplace</a>
      <a href="/subscriptions" class="btn btn-g btn-sm"><i class="fas fa-crown"></i> Upgrade Plan</a>
    </div>
  </div>
</div>

<!-- Quick Stats -->
<div class="grid grid4" style="margin-bottom:24px">
  <div class="metric">
    <div class="metric-val">0</div>
    <div class="metric-lbl">Suppliers Found</div>
    <div class="metric-tr" style="color:var(--tx3)">Search suppliers</div>
  </div>
  <div class="metric">
    <div class="metric-val" style="color:var(--a)">0</div>
    <div class="metric-lbl">Verified Batches</div>
    <div class="metric-tr" style="color:var(--tx3)">Browse quality produce</div>
  </div>
  <div class="metric">
    <div class="metric-val" style="color:var(--g2)">0</div>
    <div class="metric-lbl">Orders Placed</div>
    <div class="metric-tr" style="color:var(--tx3)">Start purchasing</div>
  </div>
  <div class="metric">
    <div class="metric-val" style="color:var(--ad)">Free Trial</div>
    <div class="metric-lbl">Current Plan</div>
    <div class="metric-tr up">Upgrade for full access</div>
  </div>
</div>

<!-- Main Content -->
<div class="grid grid2">
  <!-- Supplier Search -->
  <div class="card">
    <h3 style="font-weight:800;margin-bottom:16px"><i class="fas fa-search" style="color:var(--g)"></i> Find Verified Suppliers</h3>
    <div style="display:flex;flex-direction:column;gap:12px">
      <div>
        <label style="font-weight:600;font-size:.82rem;display:block;margin-bottom:4px">Crop Type</label>
        <select style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
          <option>All Crops</option><option>Maize</option><option>Coffee</option><option>Cocoa</option><option>Groundnuts</option><option>Beans</option>
        </select>
      </div>
      <div>
        <label style="font-weight:600;font-size:.82rem;display:block;margin-bottom:4px">District</label>
        <select style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
          <option>All Districts</option><option>Mayuge</option><option>Jinja</option><option>Iganga</option><option>Kamuli</option>
        </select>
      </div>
      <div>
        <label style="font-weight:600;font-size:.82rem;display:block;margin-bottom:4px">Quality Grade</label>
        <select style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
          <option>All Grades</option><option>Grade A</option><option>Grade B</option>
        </select>
      </div>
      <a href="/marketplace" class="btn btn-p" style="justify-content:center;margin-top:8px"><i class="fas fa-search"></i> Search Suppliers</a>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="card">
    <h3 style="font-weight:800;margin-bottom:16px"><i class="fas fa-bolt" style="color:var(--a)"></i> Quick Actions</h3>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
      <a href="/marketplace" class="card" style="text-align:center;padding:20px 12px;text-decoration:none;color:inherit">
        <div style="font-size:1.8rem;margin-bottom:8px">🛒</div>
        <div style="font-weight:600;font-size:.85rem">Marketplace</div>
      </a>
      <a href="/passport/B247391" class="card" style="text-align:center;padding:20px 12px;text-decoration:none;color:inherit">
        <div style="font-size:1.8rem;margin-bottom:8px">📜</div>
        <div style="font-weight:600;font-size:.85rem">Verify Passport</div>
      </a>
      <a href="/order-history" class="card" style="text-align:center;padding:20px 12px;text-decoration:none;color:inherit">
        <div style="font-size:1.8rem;margin-bottom:8px">🧾</div>
        <div style="font-weight:600;font-size:.85rem">Order History</div>
      </a>
      <a href="/analytics" class="card" style="text-align:center;padding:20px 12px;text-decoration:none;color:inherit">
        <div style="font-size:1.8rem;margin-bottom:8px">📊</div>
        <div style="font-weight:600;font-size:.85rem">Analytics</div>
      </a>
    </div>
  </div>
</div>

<!-- Account Info -->
<div class="card" style="margin-top:24px">
  <h3 style="font-weight:800;margin-bottom:16px"><i class="fas fa-building" style="color:var(--g)"></i> Your Account</h3>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;font-size:.9rem">
    <div>
      <div style="color:var(--tx2);font-size:.78rem;margin-bottom:4px">Name</div>
      <div style="font-weight:600"><%= typeof user !== 'undefined' && user ? user.name : 'Not set' %></div>
    </div>
    <div>
      <div style="color:var(--tx2);font-size:.78rem;margin-bottom:4px">Phone</div>
      <div style="font-weight:600"><%= typeof user !== 'undefined' && user ? user.phone : 'Not set' %></div>
    </div>
    <div>
      <div style="color:var(--tx2);font-size:.78rem;margin-bottom:4px">Role</div>
      <div><span class="tag tag-b"><%= typeof user !== 'undefined' && user ? user.role : 'BUYER' %></span></div>
    </div>
    <div>
      <div style="color:var(--tx2);font-size:.78rem;margin-bottom:4px">Plan</div>
      <div><span class="tag tag-a">Free Trial</span></div>
    </div>
  </div>
</div>
