<div class="card" style="max-width:620px;margin:0 auto">
  <h2 style="font-weight:800;margin-bottom:8px">Checkout</h2>
  <p style="color:var(--tx2);margin-bottom:20px">Confirm your purchase</p>
  
  <div style="background:#f8f9f8;padding:20px;border-radius:12px;margin-bottom:20px">
    <div style="display:flex;justify-content:space-between;margin-bottom:8px">
      <span><strong><%= crop %></strong></span>
      <span><%= tons %> tons</span>
    </div>
    <div style="display:flex;justify-content:space-between;margin-bottom:8px">
      <span>Price per kg</span>
      <span>UGX <%= price.toLocaleString() %></span>
    </div>
    <div style="display:flex;justify-content:space-between;margin-bottom:8px">
      <span>Location</span>
      <span><%= location %></span>
    </div>
    <div style="display:flex;justify-content:space-between;margin-bottom:8px">
      <span>Farmer</span>
      <span><%= farmer %></span>
    </div>
    
    <hr style="margin:12px 0">
    
    <div style="display:flex;justify-content:space-between">
      <span>Subtotal</span>
      <span>UGX <%= (tons * price * 1000).toLocaleString() %></span>
    </div>
    <div style="display:flex;justify-content:space-between">
      <span>Platform Commission (2%)</span>
      <span>UGX <%= Math.round(tons * price * 1000 * 0.02).toLocaleString() %></span>
    </div>
    <hr style="margin:12px 0">
    <div style="display:flex;justify-content:space-between;font-weight:700">
      <span>You Pay</span>
      <span>UGX <%= Math.round(tons * price * 1000 * 1.02).toLocaleString() %></span>
    </div>
    
    <div style="margin-top:12px;font-size:.75rem;color:var(--tx2)">
      Note: Farmers pay UGX 10,000/month for SMS alerts only. All other users (buyers, enterprises, NGOs) must maintain a paid subscription to access the platform.
    </div>
  </div>
  
  <div style="margin-bottom:20px">
    <label style="display:block;margin-bottom:6px;font-weight:600">Payment Method</label>
    <select style="width:100%;padding:10px;border-radius:8px">
      <option>Mobile Money (MTN)</option>
      <option>Mobile Money (Airtel)</option>
      <option>Bank Transfer</option>
    </select>
  </div>
  
  <button onclick="confirmPurchase()" class="btn btn-p" style="width:100%;padding:14px;font-size:1.05rem">
    Confirm Purchase & Pay
  </button>
  
  <div style="margin-top:16px;text-align:center">
    <a href="/marketplace" class="text-sm text-gray-500">Cancel</a>
  </div>
</div>

<script>
function confirmPurchase() {
  const btns = document.querySelectorAll('button');
  btns.forEach(b => b.disabled = true);
  
  setTimeout(() => {
    showToast('✅ Purchase successful! UGX ' + (parseInt('<%= tons %>') * parseInt('<%= price %>') * 1000).toLocaleString() + ' paid to ' + '<%= farmer %>', 'success');
    
    // Redirect to passport after success
    setTimeout(() => {
      window.location.href = '/passport/B247391';
    }, 1800);
  }, 1200);
}
</script>