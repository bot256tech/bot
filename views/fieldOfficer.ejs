        </div>
      </div>
      <div style="margin-bottom:14px">
        <label style="display:block;margin-bottom:5px;font-weight:600;font-size:.85rem">Main Crops</label>
        <div style="display:flex;flex-wrap:wrap;gap:8px">
          <label style="font-size:.82rem;display:flex;align-items:center;gap:4px"><input type="checkbox" value="Maize" class="regCrop"> Maize</label>
