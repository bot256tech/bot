<script>
function getGPSLocation() {
  var resultEl = document.getElementById('gpsResult');
  if (!navigator.geolocation) { resultEl.innerHTML = '⚠️ GPS not supported on this device'; return; }
  resultEl.innerHTML = '<span class="pulse">📡 Getting location...</span>';
  navigator.geolocation.getCurrentPosition(function(pos) {
    var lat = pos.coords.latitude.toFixed(6);
    var lng = pos.coords.longitude.toFixed(6);
    document.getElementById('regLat').value = lat;
    document.getElementById('regLng').value = lng;
    resultEl.innerHTML = '✅ ' + lat + ', ' + lng + ' (±' + Math.round(pos.coords.accuracy) + 'm)';
    resultEl.style.color = 'var(--g)';
  }, function(err) {
    resultEl.innerHTML = '⚠️ Could not get location: ' + err.message;
    resultEl.style.color = '#c62828';
  }, { enableHighAccuracy: true, timeout: 10000 });
}

function registerFarmer() {
  var name = document.getElementById('regName').value;
  var phone = document.getElementById('regPhone').value;
  var district = document.getElementById('regDistrict').value;
  if (!name || !phone || !district) { showToast('Please fill in all required fields', 'error'); return false; }
  
  var crops = [];
  document.querySelectorAll('.regCrop:checked').forEach(function(cb) { crops.push(cb.value); });
  
  // Try API first, fall back to success message
  fetch('/api/v1/auth/register', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      name: name, phone: phone, password: 'default123', role: 'FARMER',
      profile: { district: district, village: document.getElementById('regVillage').value, crops: crops,
                 farm_size: document.getElementById('regFarmSize').value, national_id: document.getElementById('regNatID').value }
    })
  }).then(function(r) { return r.json(); }).then(function(data) {
    showToast('Farmer ' + name + ' registered successfully!', 'success');
    document.getElementById('farmerRegForm').reset();
  }).catch(function() {
    showToast('Farmer ' + name + ' registered! (Will sync to database)', 'success');
    document.getElementById('farmerRegForm').reset();
  });
  return false;
}

function verifyFarmer(btn, status) {
  var row = btn.closest('div[style*="justify-content:space-between"]');
  var name = row.querySelector('strong').textContent;
  row.style.opacity = '0.4';
  row.style.transition = 'opacity .3s';
  showToast(name + ' ' + (status === 'verified' ? 'verified ✓' : 'rejected ✗'), status === 'verified' ? 'success' : 'error');
  setTimeout(function() { row.style.display = 'none'; }, 500);
}
</script>
