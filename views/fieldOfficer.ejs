          <label style="font-size:.82rem;display:flex;align-items:center;gap:4px"><input type="checkbox" value="Cocoa" class="regCrop"> Cocoa</label>
          <label style="font-size:.82rem;display:flex;align-items:center;gap:4px"><input type="checkbox" value="Groundnuts" class="regCrop"> Groundnuts</label>
          <label style="font-size:.82rem;display:flex;align-items:center;gap:4px"><input type="checkbox" value="Beans" class="regCrop"> Beans</label>
          <label style="font-size:.82rem;display:flex;align-items:center;gap:4px"><input type="checkbox" value="Cassava" class="regCrop"> Cassava</label>
          <label style="font-size:.82rem;display:flex;align-items:center;gap:4px"><input type="checkbox" value="Banana" class="regCrop"> Banana</label>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
        <div>
          <label style="display:block;margin-bottom:5px;font-weight:600;font-size:.85rem">Farm Size (acres)</label>
          <input type="number" id="regFarmSize" step="0.1" min="0" placeholder="e.g. 3.5" style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
        </div>
        <div>
          <label style="display:block;margin-bottom:5px;font-weight:600;font-size:.85rem">National ID</label>
          <input type="text" id="regNatID" placeholder="CMXXXXXXXXXX" style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
        </div>
      </div>
      
      <!-- GPS Location -->
      <div style="margin-bottom:14px;padding:14px;background:var(--bg2);border-radius:10px;border:1px solid var(--bd)">
        <label style="display:block;margin-bottom:8px;font-weight:600;font-size:.85rem"><i class="fas fa-map-marker-alt" style="color:var(--g)"></i> GPS Location</label>
        <div style="display:flex;gap:8px;align-items:center">
          <button type="button" class="btn btn-p btn-sm" onclick="getGPSLocation()" style="white-space:nowrap"><i class="fas fa-crosshairs"></i> Get Location</button>
          <div id="gpsResult" style="font-size:.82rem;color:var(--tx2)">Tap to capture GPS coordinates</div>
        </div>
        <input type="hidden" id="regLat" value="">
        <input type="hidden" id="regLng" value="">
      </div>
      
      <button type="submit" class="btn btn-p" style="width:100%;justify-content:center;padding:12px"><i class="fas fa-user-plus"></i> Register Farmer</button>
    </form>
