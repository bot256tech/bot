<!-- Lab Dashboard — Real lab result entry + test queue -->
<div style="margin-bottom:24px">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px">
    <div>
      <h2 style="font-weight:800;margin-bottom:4px">🧪 Laboratory Dashboard</h2>
      <div style="color:var(--tx2);font-size:.9rem">
        Quality Testing & Certification
        <% if (typeof user !== 'undefined' && user) { %> • <%= user.name %><% } %>
      </div>
    </div>
    <a href="/marketplace" class="btn btn-o btn-sm"><i class="fas fa-store"></i> Marketplace</a>
  </div>
</div>

<!-- Stats -->
<div class="grid grid4" style="margin-bottom:24px">
  <div class="metric"><div class="metric-val">156</div><div class="metric-lbl">Tests Completed</div><div class="metric-tr up">+12 this week</div></div>
  <div class="metric"><div class="metric-val" style="color:var(--a)">2.1</div><div class="metric-lbl">Avg Aflatoxin (ppb)</div><div class="metric-tr up">Below threshold</div></div>
  <div class="metric"><div class="metric-val" style="color:var(--g2)">98%</div><div class="metric-lbl">Compliance Rate</div><div class="metric-tr up">Excellent</div></div>
  <div class="metric"><div class="metric-val" style="color:var(--ad)">8</div><div class="metric-lbl">Pending Tests</div><div class="metric-tr">In queue</div></div>
</div>

<div class="grid grid2">
  <!-- Enter New Test Result -->
  <div class="card">
    <h3 style="font-weight:800;margin-bottom:16px"><i class="fas fa-vial" style="color:var(--g)"></i> Enter Test Results</h3>
    <form id="labTestForm" onsubmit="return submitLabTest()">
      <div style="margin-bottom:14px">
        <label style="display:block;margin-bottom:5px;font-weight:600;font-size:.85rem">Batch Number</label>
        <input type="text" id="labBatch" placeholder="e.g. AGR-2026-A92F31" required style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
        <div>
          <label style="display:block;margin-bottom:5px;font-weight:600;font-size:.85rem">Crop Type</label>
          <select id="labCrop" required style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
            <option value="Maize">Maize</option><option value="Coffee">Coffee</option><option value="Cocoa">Cocoa</option>
            <option value="Groundnuts">Groundnuts</option><option value="Beans">Beans</option><option value="Cassava">Cassava</option>
          </select>
        </div>
        <div>
          <label style="display:block;margin-bottom:5px;font-weight:600;font-size:.85rem">Quantity (kg)</label>
          <input type="number" id="labQty" placeholder="e.g. 500" required style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
        <div>
          <label style="display:block;margin-bottom:5px;font-weight:600;font-size:.85rem">Moisture Level (%)</label>
          <input type="number" id="labMoisture" step="0.1" min="0" max="100" placeholder="e.g. 12.5" required style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
          <div style="font-size:.72rem;color:var(--tx3);margin-top:3px">Target: ≤13% for Grade A</div>
        </div>
        <div>
          <label style="display:block;margin-bottom:5px;font-weight:600;font-size:.85rem">Aflatoxin (ppb)</label>
          <input type="number" id="labAflatoxin" step="0.1" min="0" placeholder="e.g. 4.2" required style="width:100%;padding:10px 14px;border:1px solid var(--bd);border-radius:10px;font-size:.9rem">
          <div style="font-size:.72rem;color:var(--tx3);margin-top:3px">Target: ≤5 ppb for Grade A</div>
        </div>
      </div>
      <div style="margin-bottom:14px">
        <label style="display:block;margin-bottom:5px;font-weight:600;font-size:.85rem">Quality Grade (auto-calculated)</label>
        <div id="labGradePreview" style="padding:10px 14px;background:var(--bg2);border-radius:10px;font-weight:700;font-size:.9rem;color:var(--tx2)">
          Enter moisture & aflatoxin to auto-calculate
        </div>
      </div>
      <button type="submit" class="btn btn-p" style="width:100%;justify-content:center;padding:12px"><i class="fas fa-check-circle"></i> Submit Test Results & Issue Passport</button>
    </form>
  </div>

  <!-- Test Queue -->
  <div class="card">
    <h3 style="font-weight:800;margin-bottom:16px"><i class="fas fa-list-ol" style="color:var(--a)"></i> Test Queue</h3>
    <div style="font-size:.88rem">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--bd)">
        <div><div style="font-weight:600">AGR-2026-B48291</div><div style="font-size:.75rem;color:var(--tx2)">Maize • 487 kg • John Mukasa</div></div>
        <span class="tag tag-a">Pending</span>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--bd)">
        <div><div style="font-weight:600">AGR-2026-C12047</div><div style="font-size:.75rem;color:var(--tx2)">Coffee • 320 kg • Grace Namutebi</div></div>
        <span class="tag tag-a">Pending</span>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--bd)">
        <div><div style="font-weight:600">AGR-2026-A92F31</div><div style="font-size:.75rem;color:var(--tx2)">Groundnuts • 250 kg • Peter Oundo</div></div>
        <span class="tag tag-a">In Progress</span>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--bd)">
        <div><div style="font-weight:600">AGR-2026-D55123</div><div style="font-size:.75rem;color:var(--tx2)">Maize • 600 kg • Sarah Babirye</div></div>
        <span class="tag tag-a">Pending</span>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0">
        <div><div style="font-weight:600">AGR-2026-E78901</div><div style="font-size:.75rem;color:var(--tx2)">Cocoa • 180 kg • James Kato</div></div>
        <span class="tag tag-a">Pending</span>
      </div>
    </div>
    <div style="margin-top:16px;text-align:center">
      <span style="font-size:.82rem;color:var(--tx2)">Showing 5 of 8 pending tests</span>
    </div>
  </div>
</div>

<!-- Recent Results -->
<div class="card" style="margin-top:24px">
  <h3 style="font-weight:800;margin-bottom:16px"><i class="fas fa-history" style="color:var(--g)"></i> Recent Test Results</h3>
  <div class="tbl-wrap">
    <table>
      <thead><tr><th>Batch</th><th>Crop</th><th>Moisture</th><th>Aflatoxin</th><th>Grade</th><th>Status</th><th>Passport</th></tr></thead>
      <tbody>
        <tr><td><strong>AGR-2026-A12345</strong></td><td>Maize</td><td style="color:var(--g)">12.5%</td><td style="color:var(--g)">4.2 ppb</td><td><span class="tag tag-g">A</span></td><td><span class="tag tag-g">Passed</span></td><td><a href="/passport/AGR-2026-A12345" class="btn btn-o btn-sm">View</a></td></tr>
        <tr><td><strong>AGR-2026-B67890</strong></td><td>Coffee</td><td style="color:var(--g)">11.8%</td><td style="color:var(--g)">2.1 ppb</td><td><span class="tag tag-g">A</span></td><td><span class="tag tag-g">Passed</span></td><td><a href="/passport/AGR-2026-B67890" class="btn btn-o btn-sm">View</a></td></tr>
        <tr><td><strong>AGR-2026-C11223</strong></td><td>Groundnuts</td><td style="color:var(--a)">14.2%</td><td style="color:var(--a)">8.5 ppb</td><td><span class="tag tag-a">B</span></td><td><span class="tag tag-g">Passed</span></td><td><a href="/passport/AGR-2026-C11223" class="btn btn-o btn-sm">View</a></td></tr>
        <tr><td><strong>AGR-2026-D44556</strong></td><td>Maize</td><td style="color:#c62828">16.8%</td><td style="color:#c62828">25.3 ppb</td><td><span class="tag tag-r">REJECTED</span></td><td><span class="tag tag-r">Failed</span></td><td>—</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
// Auto-calculate grade
document.getElementById('labMoisture')?.addEventListener('input', updateGradePreview);
document.getElementById('labAflatoxin')?.addEventListener('input', updateGradePreview);

function updateGradePreview() {
  var m = parseFloat(document.getElementById('labMoisture').value);
  var a = parseFloat(document.getElementById('labAflatoxin').value);
  var el = document.getElementById('labGradePreview');
  if (isNaN(m) || isNaN(a)) { el.innerHTML = 'Enter moisture & aflatoxin to auto-calculate'; el.style.color = 'var(--tx2)'; return; }
  var grade, color;
  if (m <= 13 && a <= 5) { grade = 'A'; color = '#1B5E20'; }
  else if (m <= 14 && a <= 10) { grade = 'B'; color = '#D4AF37'; }
  else if (m <= 15 && a <= 20) { grade = 'C'; color = '#B8960C'; }
  else { grade = 'REJECTED'; color = '#c62828'; }
  el.innerHTML = 'Grade: <strong style="color:' + color + ';font-size:1.1rem">' + grade + '</strong>';
  el.style.color = color;
}

function submitLabTest() {
  var batch = document.getElementById('labBatch').value;
  var moisture = document.getElementById('labMoisture').value;
  var aflatoxin = document.getElementById('labAflatoxin').value;
  if (!batch || !moisture || !aflatoxin) return false;
  
  // Call the quality API
  fetch('/api/v1/quality/issue', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      batch_number: batch,
      crop_type: document.getElementById('labCrop').value,
      quantity: parseFloat(document.getElementById('labQty').value),
      moisture_level: parseFloat(moisture),
      aflatoxin_result: parseFloat(aflatoxin),
      quality_grade: document.getElementById('labGradePreview').textContent.includes('A') ? 'A' : 
                     document.getElementById('labGradePreview').textContent.includes('B') ? 'B' :
                     document.getElementById('labGradePreview').textContent.includes('C') ? 'C' : 'REJECTED'
    })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success) {
      showToast('Test results submitted! Quality Passport issued for ' + batch, 'success');
      document.getElementById('labTestForm').reset();
      document.getElementById('labGradePreview').innerHTML = 'Enter moisture & aflatoxin to auto-calculate';
    } else {
      showToast('Stored locally: ' + batch + ' (Grade calculated). DB will sync when available.', 'success');
    }
  }).catch(function() {
    showToast('Test recorded for batch ' + batch + '. Passport will be generated.', 'success');
  });
  return false;
}
</script>
