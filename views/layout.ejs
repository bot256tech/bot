<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <%- include('partials/head', { title }) %>
</head>
<body>
  <!-- Page Load Transition -->
  <div class="page-loader">
    <div class="spinner"></div>
  </div>

  <!-- Sidebar Overlay (mobile) -->
  <div class="sidebar-overlay" onclick="closeSidebar()"></div>

  <div class="app">
    <%- include('partials/sidebar', { page }) %>
    <main class="main">
      <%- include('partials/topbar', { page, title }) %>
      <div class="page active" id="pg-<%= page %>">
        <%- include(body, data) %>
      </div>
      <!-- Bottom padding for mobile bottom bar -->
      <div style="height:70px" class="d-block d-md-none"></div>
    </main>
  </div>

  <!-- Mobile Bottom App Bar -->
  <div class="bottom-bar d-flex d-md-none">
    <a href="/" class="bottom-item <%= page === 'landing' || page === 'landingPage' || page === 'bootstrapLanding' ? 'active' : '' %>">
      <i class="fas fa-home"></i><span>Home</span>
    </a>
    <a href="/marketplace" class="bottom-item <%= page === 'marketplace' ? 'active' : '' %>">
      <i class="fas fa-store"></i><span>Market</span>
    </a>
    <a href="/ai-advisor" class="bottom-item <%= page === 'ai-advisor' || page === 'ai-disease' ? 'active' : '' %>">
      <i class="fas fa-brain"></i><span>AI</span>
    </a>
    <a href="/iot-dryer" class="bottom-item <%= page === 'iot-dryer' || page === 'dryer' ? 'active' : '' %>">
      <i class="fas fa-solar-panel"></i><span>IoT</span>
    </a>
    <a href="/roles" class="bottom-item">
      <i class="fas fa-user"></i><span>Account</span>
    </a>
  </div>

  <!-- Install App Prompt -->
  <div id="installPrompt" style="display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:999;background:white;border-radius:16px;padding:14px 20px;box-shadow:0 8px 32px rgba(0,0,0,.15);border:1px solid #e8e8e8;max-width:400px;width:90%">
    <div style="display:flex;align-items:center;gap:12px">
      <img src="/images/icon-192.png" alt="" style="width:40px;height:40px;border-radius:10px">
      <div style="flex:1">
        <div style="font-weight:700;font-size:.85rem;color:#333">Install AGRICHAIN 360</div>
        <div style="font-size:.72rem;color:#888;margin-top:1px">Add to home screen for the full app</div>
      </div>
      <button onclick="installApp()" style="padding:7px 16px;border-radius:10px;border:none;background:#1B5E20;color:white;font-weight:600;font-size:.8rem;cursor:pointer;white-space:nowrap">Install</button>
      <button onclick="dismissInstall()" style="background:none;border:none;font-size:1.1rem;color:#ccc;cursor:pointer;padding:2px">&times;</button>
    </div>
  </div>
  <%- include('partials/scripts') %>
  <script>
  let deferredPrompt=null;
  window.addEventListener('beforeinstallprompt',(e)=>{e.preventDefault();deferredPrompt=e;setTimeout(()=>{var el=document.getElementById('installPrompt');if(el)el.style.display='block'},5000)});
  function installApp(){if(deferredPrompt){deferredPrompt.prompt();deferredPrompt.userChoice.then(()=>{deferredPrompt=null;var el=document.getElementById('installPrompt');if(el)el.style.display='none'})}}
  function dismissInstall(){var el=document.getElementById('installPrompt');if(el)el.style.display='none'}
  window.addEventListener('appinstalled',()=>{var el=document.getElementById('installPrompt');if(el)el.style.display='none';deferredPrompt=null});
  </script>
</body>
</html>
