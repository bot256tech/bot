<div class="card" style="max-width:480px;margin:40px auto">
  <h2 style="font-weight:800;margin-bottom:8px">Welcome to AGRICHAIN 360</h2>
  <p style="color:var(--tx2);margin-bottom:24px">Please select your role to continue</p>
  
  <form action="/login" method="POST">
    <div style="margin-bottom:16px">
      <label style="display:block;margin-bottom:6px;font-weight:600">Select Role</label>
      <select name="role" required style="width:100%;padding:12px;border-radius:10px">
        <option value="farmer">👨‍🌾 Farmer</option>
        <option value="buyer">🏢 Enterprise Buyer</option>
        <option value="field_officer">🧑‍🌾 Field Officer</option>
        <option value="quality_officer">🔬 Quality Officer</option>
        <option value="lab">🧪 Laboratory Staff</option>
        <option value="admin">⚙️ Administrator</option>
      </select>
    </div>
    
    <div style="margin-bottom:16px">
      <label style="display:block;margin-bottom:6px;font-weight:600">Phone Number</label>
      <input type="tel" name="phone" value="+256774123456" required style="width:100%;padding:12px;border-radius:10px">
    </div>
    
    <button type="submit" class="btn btn-p" style="width:100%;padding:14px">Login / Continue</button>
  </form>
  
  <div style="margin-top:20px;text-align:center;font-size:0.85rem;color:var(--tx2)">
    Don't have an account? <a href="/roles">Create one</a>
  </div>
</div>