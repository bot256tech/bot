<div class="card mb20">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
    <h3 style="font-weight:800">📋 My Listings — Manage Your Crops</h3>
    <button class="btn btn-p btn-sm" onclick="showAddListingModal()">+ Add New Listing</button>
  </div>
  
  <div class="tbl-wrap">
    <table>
      <thead>
        <tr>
          <th>Batch ID</th>
          <th>Crop</th>
          <th>Quantity</th>
          <th>Price/kg</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>B247</strong></td>
          <td>Maize</td>
          <td>15 tons</td>
          <td>UGX 1,800</td>
          <td><span class="tag tag-g">Active</span></td>
          <td>
            <button class="btn btn-o btn-sm" onclick="editListing(0)">Edit</button>
            <button class="btn btn-o btn-sm" onclick="removeListing(0)">Remove</button>
          </td>
        </tr>
        <tr>
          <td><strong>B155</strong></td>
          <td>Coffee</td>
          <td>5 tons</td>
          <td>UGX 8,500</td>
          <td><span class="tag tag-g">Active</span></td>
          <td>
            <button class="btn btn-o btn-sm" onclick="editListing(1)">Edit</button>
            <button class="btn btn-o btn-sm" onclick="removeListing(1)">Remove</button>
          </td>
        </tr>
        <tr>
          <td><strong>B201</strong></td>
          <td>Cocoa</td>
          <td>3 tons</td>
          <td>UGX 10,000</td>
          <td><span class="tag tag-a">Pending Approval</span></td>
          <td>
            <button class="btn btn-o btn-sm" onclick="editListing(2)">Edit</button>
            <button class="btn btn-o btn-sm" onclick="removeListing(2)">Remove</button>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<!-- Add Listing Modal -->
<div id="addListingModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:100;align-items:center;justify-content:center">
  <div class="card" style="width:420px">
    <h3 style="margin-bottom:16px">Add New Listing</h3>
    
    <div style="margin-bottom:12px">
      <label>Crop</label>
      <select id="newCrop" style="width:100%;padding:8px">
        <option>Maize</option>
        <option>Coffee</option>
        <option>Cocoa</option>
        <option>Groundnuts</option>
      </select>
    </div>
    
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
      <div>
        <label>Quantity (tons)</label>
        <input type="number" id="newTons" value="10" style="width:100%">
      </div>
      <div>
        <label>Price per kg</label>
        <input type="number" id="newPrice" value="1800" style="width:100%">
      </div>
    </div>
    
    <div style="margin-top:20px;display:flex;gap:8px">
      <button class="btn btn-p" onclick="addListing()" style="flex:1">Add Listing</button>
      <button class="btn btn-o" onclick="hideAddModal()" style="flex:1">Cancel</button>
    </div>
  </div>
</div>

<script>
function showAddListingModal() {
  document.getElementById('addListingModal').style.display = 'flex';
}

function hideAddModal() {
  document.getElementById('addListingModal').style.display = 'none';
}

function addListing() {
  const crop = document.getElementById('newCrop').value;
  const tons = document.getElementById('newTons').value;
  const price = document.getElementById('newPrice').value;
  
  showToast(`New listing added: ${crop} — ${tons} tons @ UGX ${price}/kg`, 'success');
  hideAddModal();
  
  // In real app, this would POST to backend
  setTimeout(() => location.reload(), 1500);
}

function editListing(index) {
  showToast('Edit mode opened (demo)', 'success');
}

function removeListing(index) {
  if (confirm('Remove this listing from the marketplace?')) {
    showToast('Listing removed successfully', 'success');
  }
}
</script>