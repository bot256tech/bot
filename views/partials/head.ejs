<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title : 'AGRICHAIN 360™' %></title>
<meta name="description" content="AGRICHAIN 360 — Uganda's Complete Post-Harvest Platform. Connect farmers, buyers, and service providers with verified quality, real-time IoT monitoring, and digital traceability.">
<meta name="theme-color" content="#1B5E20">
<meta name="author" content="Batesa Ibrahim">
<link rel="icon" href="/images/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="stylesheet" href="/css/main.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  /* ═══════════════ DESIGN SYSTEM — 4-COLOR PALETTE ═══════════════ */
  /* Deep Green #1B5E20 | Gold #D4AF37 | Charcoal #333333 | Cream #FAFAF5 */
  :root {
    --g: #1B5E20; --g2: #2E7D32; --gd: #0d3b0d;
    --a: #D4AF37; --ad: #B8960C;
    --br: #6D4C41;
    --bg: #FAFAF5; --bg2: #F2F0E8;
    --card: #fff; --card2: #FAFAF5;
    --tx: #333333; --tx2: #666;
    --bd: rgba(27,94,32,.12);
    --sh: 0 4px 20px rgba(27,94,32,.06);
    --shl: 0 12px 40px rgba(27,94,32,.12);
    --gl: rgba(27,94,32,.06);
    --glb: rgba(27,94,32,.03);
    --nav: rgba(250,250,245,.92);
    --rd: 16px;
    --sidebar: 260px;
  }
  .dark {
    --bg: #0F1A0F; --bg2: #162016;
    --card: #1A2B1A; --card2: #1F301F;
    --tx: #E8E8E0; --tx2: #999;
    --bd: rgba(45,128,50,.2);
    --sh: 0 4px 20px rgba(0,0,0,.3);
    --shl: 0 12px 40px rgba(0,0,0,.5);
    --gl: rgba(27,94,32,.15);
    --glb: rgba(27,94,32,.08);
    --nav: rgba(15,26,15,.95);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{font-family:'Inter',system-ui,sans-serif;font-size:15px;background:var(--bg);color:var(--tx);overflow-x:hidden;line-height:1.5;min-height:100vh}
  h1,h2,h3,h4{font-family:'Space Grotesk','Inter',sans-serif;letter-spacing:-.02em}
  a{color:var(--g);text-decoration:none}
  ::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:var(--bd);border-radius:3px}

  /* Layout */
  .app{display:flex;min-height:100vh}
  .sidebar{width:var(--sidebar);background:var(--card);border-right:1px solid var(--bd);position:fixed;top:0;left:0;bottom:0;z-index:50;overflow-y:auto;display:flex;flex-direction:column;padding:20px 0;transition:transform .3s}
  .side-brand{padding:0 20px 20px;border-bottom:1px solid var(--bd);margin-bottom:8px;font-family:'Space Grotesk',sans-serif;font-weight:800;font-size:1.2rem;color:var(--g);display:flex;align-items:center;gap:8px}
  .side-nav{flex:1;padding:0 12px}
  .nav-section{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--tx2);padding:16px 12px 6px}
  .nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;font-size:.85rem;font-weight:500;color:var(--tx2);cursor:pointer;transition:all .2s;margin-bottom:2px;border:none;background:none;width:100%;text-align:left;text-decoration:none}
  .nav-item:hover{background:var(--bg2);color:var(--tx)}
  .nav-item.active{background:var(--g);color:#fff;font-weight:600}
  .nav-item .badge{margin-left:auto;background:var(--a);color:#3e2723;font-size:.65rem;font-weight:800;padding:2px 8px;border-radius:20px}
  .main{flex:1;margin-left:var(--sidebar);min-height:100vh}
  .topbar{position:sticky;top:0;z-index:40;background:var(--nav);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:60px}
  .topbar-left{display:flex;align-items:center;gap:12px;font-weight:700;font-size:1.05rem}
  .topbar-right{display:flex;align-items:center;gap:8px;flex-shrink:0;overflow:hidden}
  .page{display:block;padding:28px;animation:fadeSlide .35s ease-out}
  @keyframes fadeSlide{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

  /* Components */
  .card{background:var(--card);border-radius:var(--rd);padding:24px;border:1px solid var(--bd);box-shadow:var(--sh);transition:all .3s}
  .card:hover{box-shadow:var(--shl)}
  .grid{display:grid;gap:20px}
  .grid2{grid-template-columns:repeat(auto-fit,minmax(300px,1fr))}
  .grid3{grid-template-columns:repeat(auto-fit,minmax(220px,1fr))}
  .grid4{grid-template-columns:repeat(auto-fit,minmax(180px,1fr))}
  .metric{text-align:center;padding:20px;background:var(--card);border-radius:var(--rd);border:1px solid var(--bd)}
  .metric-val{font-size:1.8rem;font-weight:900;font-family:'Space Grotesk',sans-serif;color:var(--g)}
  .metric-lbl{font-size:.75rem;color:var(--tx2);margin-top:4px}
  .metric-tr{font-size:.7rem;margin-top:4px;font-weight:600}
  .metric-tr.up{color:var(--g)}.metric-tr.warn{color:#e65100}

  /* Buttons */
  .btn{display:inline-flex;align-items:center;gap:8px;padding:10px 22px;border-radius:50px;font-weight:700;font-size:.85rem;cursor:pointer;transition:all .25s;border:none;text-decoration:none}
  .btn-p{background:var(--g);color:#fff;box-shadow:0 4px 16px rgba(27,94,32,.25)}
  .btn-p:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(27,94,32,.35)}
  .btn-g{background:var(--a);color:#3e2723;box-shadow:0 4px 16px rgba(212,175,55,.25)}
  .btn-g:hover{transform:translateY(-2px)}
  .btn-o{border:2px solid var(--bd);background:transparent;color:var(--tx)}
  .btn-o:hover{border-color:var(--g);color:var(--g)}
  .btn-sm{padding:6px 14px;font-size:.75rem}

  /* Tags & Tables */
  .tag{display:inline-block;font-size:.7rem;font-weight:700;padding:4px 12px;border-radius:50px}
  .tag-g{background:rgba(27,94,32,.1);color:var(--g)}
  .tag-a{background:rgba(212,175,55,.15);color:var(--ad)}
  .tag-b{background:rgba(2,119,189,.1);color:#0277bd}
  .tag-r{background:rgba(198,40,40,.1);color:#c62828}
  .tbl-wrap{overflow-x:auto;border-radius:var(--rd);border:1px solid var(--bd)}
  table{width:100%;border-collapse:collapse;font-size:.82rem}
  thead th{background:var(--g);color:#fff;padding:12px 14px;text-align:left;font-weight:700;font-size:.75rem;text-transform:uppercase;letter-spacing:.05em}
  tbody td{padding:10px 14px;border-bottom:1px solid var(--bd)}
  tbody tr:nth-child(even){background:var(--card2)}
  tbody tr:hover{background:rgba(27,94,32,.03)}

  /* Charts, Chat, Progress */
  .chart-wrap{position:relative;width:100%;height:300px}
  .chart-wrap canvas{width:100%!important}
  .chat{background:var(--bg2);border-radius:var(--rd);padding:16px;max-height:380px;overflow-y:auto}
  .chat-msg{display:flex;gap:10px;margin-bottom:12px;font-size:.83rem}
  .chat-msg.user{flex-direction:row-reverse}
  .chat-bub{padding:10px 14px;border-radius:14px;max-width:75%;line-height:1.5}
  .chat-bub.ai{background:var(--card);border:1px solid var(--bd);border-bottom-left-radius:4px}
  .chat-bub.user{background:var(--g);color:#fff;border-bottom-right-radius:4px}
  .progress{height:8px;background:var(--bd);border-radius:4px;overflow:hidden}
  .progress-fill{height:100%;border-radius:4px;transition:width 1.2s ease}
  .progress-fill.g{background:var(--g)}.progress-fill.a{background:var(--a)}

  /* Misc */
  .pulse{animation:pulse 2s infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
  .flex{display:flex}.gap8{gap:8px}.gap12{gap:12px}.gap16{gap:16px}
  .items-center{align-items:center}.justify-between{justify-content:space-between}
  .mt12{margin-top:12px}.mt16{margin-top:16px}.mt20{margin-top:20px}.mt24{margin-top:24px}
  .mb16{margin-bottom:16px}.mb20{margin-bottom:20px}
  .text-center{text-align:center}.text-sm{font-size:.82rem}.text-xs{font-size:.73rem}
  .font-bold{font-weight:700}.text-g{color:var(--g)}.text-a{color:var(--a)}

  /* Toast */
  .toast{position:fixed;top:80px;right:24px;z-index:200;background:var(--card);border:1px solid var(--bd);border-radius:12px;padding:14px 20px;box-shadow:var(--shl);display:flex;align-items:center;gap:10px;font-size:.85rem;animation:slideIn .3s ease-out;max-width:360px}
  .toast.success{border-left:4px solid var(--g)}
  @keyframes slideIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}

  /* Light/Dark */
  .light .sun-icon{display:none}.dark .moon-icon{display:none}

  /* Search */
  .search-box{display:flex;align-items:center;gap:8px;background:var(--bg2);border-radius:50px;padding:8px 16px;border:1px solid var(--bd)}
  .search-box input{border:none;background:transparent;outline:none;font-size:.85rem;color:var(--tx);width:200px}
  .search-box i{color:var(--tx2)}
  input[type=text],select{padding:10px 14px;border:1px solid var(--bd);border-radius:50px;font-size:.85rem;background:var(--bg);color:var(--tx);outline:none}

  /* ═══════════════ LANDING PAGE MOBILE ═══════════════ */
  @media(max-width:900px){
    .page > div[style*="max-width:1200px"]{padding:20px 16px!important}
    .page h1[style*="font-size:3"]{font-size:1.8rem!important;line-height:1.2!important}
    .page h1[style*="font-size:2"]{font-size:1.5rem!important}
    .page p[style*="font-size:1.1"]{font-size:.95rem!important}
    .page div[style*="display:flex"][style*="gap:12px"]{flex-direction:column;align-items:center}
    .page div[style*="display:flex"][style*="gap:12px"] .btn{width:100%;text-align:center;max-width:300px}
    .page img[style]{max-width:100%!important;height:auto!important}
    .page div[style*="display:grid"]{grid-template-columns:1fr!important}
  }

  @media(max-width:480px){
    .page h1[style*="font-size:3"]{font-size:1.5rem!important}
    .page h1[style*="font-size:2"]{font-size:1.3rem!important}
    .page h2{font-size:1.1rem!important}
    .page div[style*="font-size:2.5rem"]{font-size:2rem!important}
  }

  /* ═══════════════ MOBILE RESPONSIVE ═══════════════ */
  .menu-btn{display:none;background:none;border:none;font-size:1.4rem;color:var(--tx);cursor:pointer;padding:8px}

  /* Sidebar overlay (click to close) */
  .sidebar-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:45;opacity:0;transition:opacity .3s}
  .sidebar-overlay.active{display:block;opacity:1}

  @media(max-width:900px){
    .sidebar{transform:translateX(-100%);width:280px;box-shadow:4px 0 20px rgba(0,0,0,.2)}
    .sidebar.open{transform:translateX(0)}
    .main{margin-left:0}
    .menu-btn{display:block}
    .topbar{padding:0 12px;height:56px}
    .topbar-right{gap:6px}
    .topbar-right .search-box{display:none}
    .topbar-right .btn{padding:6px 10px;font-size:.72rem}
    .topbar-right .btn-g{display:none}
    .topbar-left span{font-size:.9rem}
    .page{padding:16px}
    .grid2,.grid3,.grid4{grid-template-columns:1fr}
    .metric-val{font-size:1.4rem}
    .card{padding:16px}
    h1{font-size:1.4rem}
    h2{font-size:1.15rem}
    h3{font-size:1rem}
    table{font-size:.75rem}
    thead th,tbody td{padding:8px 6px}
    .toast{top:64px;right:12px;left:12px;max-width:none}
    .chat-wrap{padding:12px}
    .search-box input{width:120px}
  }

  @media(max-width:480px){
    .topbar-right .btn-o{display:none}
    .page{padding:12px}
    .card{padding:12px;border-radius:12px}
    .metric{padding:14px}
    .metric-val{font-size:1.2rem}
    .btn{padding:8px 16px;font-size:.8rem}
    .grid2,.grid3,.grid4{gap:12px}
  }
  /* ═══════════════ SMOOTH TRANSITIONS & ANIMATIONS ═══════════════ */
  html{scroll-behavior:smooth}

  /* Page Load Transition */
  .page-loader{position:fixed;top:0;left:0;right:0;bottom:0;background:var(--bg);z-index:9999;display:flex;align-items:center;justify-content:center;transition:opacity .6s ease,visibility .6s ease}
  .page-loader.loaded{opacity:0;visibility:hidden;pointer-events:none}
  .page-loader .spinner{width:40px;height:40px;border:3px solid var(--bd);border-top-color:var(--g);border-radius:50%;animation:spin .8s linear infinite}
  @keyframes spin{to{transform:rotate(360deg)}}

  /* Scroll-triggered fade-in */
  .fade-up{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}
  .fade-up.visible{opacity:1;transform:translateY(0)}
  .fade-left{opacity:0;transform:translateX(-30px);transition:opacity .7s ease,transform .7s ease}
  .fade-left.visible{opacity:1;transform:translateX(0)}
  .fade-right{opacity:0;transform:translateX(30px);transition:opacity .7s ease,transform .7s ease}
  .fade-right.visible{opacity:1;transform:translateX(0)}
  .scale-in{opacity:0;transform:scale(.9);transition:opacity .5s ease,transform .5s ease}
  .scale-in.visible{opacity:1;transform:scale(1)}

  /* Stagger children */
  .stagger > *{opacity:0;transform:translateY(20px);transition:opacity .5s ease,transform .5s ease}
  .stagger.visible > *:nth-child(1){transition-delay:.1s}
  .stagger.visible > *:nth-child(2){transition-delay:.2s}
  .stagger.visible > *:nth-child(3){transition-delay:.3s}
  .stagger.visible > *:nth-child(4){transition-delay:.4s}
  .stagger.visible > *:nth-child(5){transition-delay:.5s}
  .stagger.visible > *:nth-child(6){transition-delay:.6s}
  .stagger.visible > *{opacity:1;transform:translateY(0)}

  /* Card enhanced hover */
  .card-lift{transition:all .35s cubic-bezier(.25,.8,.25,1)}
  .card-lift:hover{transform:translateY(-8px);box-shadow:var(--shl)}

  /* Image styles */
  .img-cover{width:100%;height:100%;object-fit:cover;border-radius:var(--rd)}
  .img-rounded{border-radius:16px;overflow:hidden}
  .img-shadow{box-shadow:0 8px 30px rgba(0,0,0,.12)}

  /* Skeleton loading */
  .skeleton{background:linear-gradient(90deg,var(--bg2) 25%,var(--bd) 50%,var(--bg2) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:8px}
  @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

  /* Floating animation */
  .float{animation:float 3s ease-in-out infinite}
  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}

  /* Gradient text */
  .gradient-text{background:linear-gradient(135deg,var(--g),var(--g2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

  /* Bottom App Bar (mobile only) */
  .bottom-bar{display:none;position:fixed;bottom:0;left:0;right:0;height:60px;background:var(--card);border-top:1px solid var(--bd);z-index:50;box-shadow:0 -4px 20px rgba(0,0,0,.08);justify-content:space-around;align-items:center;padding:0 8px}
  .bottom-item{display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 12px;color:var(--tx2);font-size:.6rem;font-weight:600;cursor:pointer;transition:color .2s;text-decoration:none;border-radius:8px}
  .bottom-item.active,.bottom-item:hover{color:var(--g)}
  .bottom-item i{font-size:1.15rem}

  /* Counter animation */
  .counter{display:inline-block;transition:all .3s}

  /* Glassmorphism */
  .glass{background:rgba(255,255,255,.7);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.3)}
  .dark .glass{background:rgba(24,32,24,.7);border:1px solid rgba(255,255,255,.08)}

  /* Section divider wave */
  .wave-divider{position:relative;width:100%;overflow:hidden;line-height:0}
  .wave-divider svg{position:relative;display:block;width:calc(100% + 1.3px);height:60px}

  /* Print */
  @media print{.sidebar,.topbar,.bottom-bar,.page-loader,.btn{display:none!important}.main{margin-left:0!important}}
</style>