<div style="max-width:1100px;margin:0 auto;padding:20px">
  <div style="text-align:center;margin-bottom:32px">
    <h1 style="font-size:2rem;font-weight:800;margin-bottom:8px">Join AGRICHAIN 360</h1>
    <p style="color:var(--tx2);font-size:1rem">Select your role to get started — each role has a tailored experience</p>
  </div>

  <div class="grid grid3" style="gap:16px">
    <!-- Farmer -->
    <a href="/signup?role=farmer" class="card" style="text-decoration:none;color:inherit;text-align:center;padding:28px 20px;transition:all .3s;cursor:pointer" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='var(--g)'" onmouseout="this.style.transform='';this.style.borderColor=''">
      <div style="font-size:3rem;margin-bottom:12px">👨‍🌾</div>
      <div style="font-weight:800;font-size:1.1rem;margin-bottom:6px">Farmer</div>
      <div style="font-size:.82rem;color:var(--tx2);line-height:1.5">Register your farm, book solar drying, get quality certificates, sell produce, access credit</div>
      <div class="btn btn-p btn-sm" style="margin-top:14px;display:inline-flex">Register as Farmer</div>
    </a>

    <!-- Village Agent -->
    <a href="/signup?role=village_agent" class="card" style="text-decoration:none;color:inherit;text-align:center;padding:28px 20px;transition:all .3s;cursor:pointer" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='var(--g)'" onmouseout="this.style.transform='';this.style.borderColor=''">
      <div style="font-size:3rem;margin-bottom:12px">🤝</div>
      <div style="font-weight:800;font-size:1.1rem;margin-bottom:6px">Village Agent</div>
      <div style="font-size:.82rem;color:var(--tx2);line-height:1.5">Register farmers in your area, map gardens with GPS, collect produce, earn commissions</div>
      <div class="btn btn-p btn-sm" style="margin-top:14px;display:inline-flex">Become an Agent</div>
    </a>

    <!-- Enterprise Buyer -->
    <a href="/signup?role=buyer" class="card" style="text-decoration:none;color:inherit;text-align:center;padding:28px 20px;transition:all .3s;cursor:pointer" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='var(--g)'" onmouseout="this.style.transform='';this.style.borderColor=''">
      <div style="font-size:3rem;margin-bottom:12px">🏢</div>
      <div style="font-weight:800;font-size:1.1rem;margin-bottom:6px">Enterprise Buyer</div>
      <div style="font-size:.82rem;color:var(--tx2);line-height:1.5">Source verified produce, download quality certificates, track supply chain, manage procurement</div>
      <div class="btn btn-p btn-sm" style="margin-top:14px;display:inline-flex">Register as Buyer</div>
    </a>

    <!-- Service Partner -->
    <a href="/signup?role=partner" class="card" style="text-decoration:none;color:inherit;text-align:center;padding:28px 20px;transition:all .3s;cursor:pointer" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='var(--g)'" onmouseout="this.style.transform='';this.style.borderColor=''">
      <div style="font-size:3rem;margin-bottom:12px">☀️</div>
      <div style="font-weight:800;font-size:1.1rem;margin-bottom:6px">Service Partner</div>
      <div style="font-size:.82rem;color:var(--tx2);line-height:1.5">Solar dryer operator, quality lab, transporter, or warehouse — offer your services to farmers</div>
      <div class="btn btn-p btn-sm" style="margin-top:14px;display:inline-flex">Register as Partner</div>
    </a>

    <!-- Input Dealer -->
    <a href="/signup?role=input_dealer" class="card" style="text-decoration:none;color:inherit;text-align:center;padding:28px 20px;transition:all .3s;cursor:pointer" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='var(--g)'" onmouseout="this.style.transform='';this.style.borderColor=''">
      <div style="font-size:3rem;margin-bottom:12px">🌱</div>
      <div style="font-weight:800;font-size:1.1rem;margin-bottom:6px">Agro-Input Dealer</div>
      <div style="font-size:.82rem;color:var(--tx2);line-height:1.5">Sell verified seeds, fertilizer, and pesticides. Get certified and reach thousands of farmers</div>
      <div class="btn btn-p btn-sm" style="margin-top:14px;display:inline-flex">Register as Dealer</div>
    </a>

    <!-- Cooperative -->
    <a href="/signup?role=cooperative" class="card" style="text-decoration:none;color:inherit;text-align:center;padding:28px 20px;transition:all .3s;cursor:pointer" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='var(--g)'" onmouseout="this.style.transform='';this.style.borderColor=''">
      <div style="font-size:3rem;margin-bottom:12px">👥</div>
      <div style="font-weight:800;font-size:1.1rem;margin-bottom:6px">Cooperative</div>
      <div style="font-size:.82rem;color:var(--tx2);line-height:1.5">Manage members, coordinate bulk sales, distribute inputs, track savings and loans</div>
      <div class="btn btn-p btn-sm" style="margin-top:14px;display:inline-flex">Register Cooperative</div>
    </a>

    <!-- NGO / Development Partner -->
    <a href="/signup?role=ngo" class="card" style="text-decoration:none;color:inherit;text-align:center;padding:28px 20px;transition:all .3s;cursor:pointer" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='var(--g)'" onmouseout="this.style.transform='';this.style.borderColor=''">
      <div style="font-size:3rem;margin-bottom:12px">🌍</div>
      <div style="font-weight:800;font-size:1.1rem;margin-bottom:6px">NGO / Development Partner</div>
      <div style="font-size:.82rem;color:var(--tx2);line-height:1.5">Access regional analytics, track impact, coordinate training programs, monitor food security</div>
      <div class="btn btn-g btn-sm" style="margin-top:14px;display:inline-flex">Connect as NGO</div>
    </a>

    <!-- Financial Institution -->
    <a href="/signup?role=finance" class="card" style="text-decoration:none;color:inherit;text-align:center;padding:28px 20px;transition:all .3s;cursor:pointer" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='var(--g)'" onmouseout="this.style.transform='';this.style.borderColor=''">
      <div style="font-size:3rem;margin-bottom:12px">🏦</div>
      <div style="font-weight:800;font-size:1.1rem;margin-bottom:6px">Financial Institution</div>
      <div style="font-size:.82rem;color:var(--tx2);line-height:1.5">Access farmer credit profiles, offer digital loans, manage repayments, view risk scores</div>
      <div class="btn btn-g btn-sm" style="margin-top:14px;display:inline-flex">Connect as Financier</div>
    </a>

    <!-- Researcher -->
    <a href="/signup?role=researcher" class="card" style="text-decoration:none;color:inherit;text-align:center;padding:28px 20px;transition:all .3s;cursor:pointer" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='var(--g)'" onmouseout="this.style.transform='';this.style.borderColor=''">
      <div style="font-size:3rem;margin-bottom:12px">🔬</div>
      <div style="font-weight:800;font-size:1.1rem;margin-bottom:6px">Researcher / Agronomist</div>
      <div style="font-size:.82rem;color:var(--tx2);line-height:1.5">Access anonymized agricultural data, disease patterns, yield trends, soil classifications</div>
      <div class="btn btn-g btn-sm" style="margin-top:14px;display:inline-flex">Register as Researcher</div>
    </a>
  </div>

  <div style="text-align:center;margin-top:32px;font-size:.9rem;color:var(--tx2)">
    Already have an account? <a href="/login" style="font-weight:700">Login here</a>
  </div>
</div>
