<div class="card" style="max-width:520px;margin:40px auto">
  <h2 style="font-weight:800;margin-bottom:8px">Create Your Account</h2>
  <p style="color:var(--tx2);margin-bottom:24px">Join AGRICHAIN 360 and transform post-harvest agriculture</p>
  
  <form action="/signup" method="POST">
    <div style="margin-bottom:16px">
      <label style="display:block;margin-bottom:6px;font-weight:600">Full Name</label>
      <input type="text" name="name" placeholder="John Mukasa" required style="width:100%;padding:12px;border-radius:10px">
    </div>
    
    <div style="margin-bottom:16px">
      <label style="display:block;margin-bottom:6px;font-weight:600">Phone Number</label>
      <input type="tel" name="phone" value="+256" required style="width:100%;padding:12px;border-radius:10px">
    </div>
    
    <div style="margin-bottom:20px">
      <label style="display:block;margin-bottom:6px;font-weight:600">I am a...</label>
      <select name="role" required style="width:100%;padding:12px;border-radius:10px">
        <option value="farmer">👨‍🌾 Farmer</option>
        <option value="buyer">🏢 Enterprise Buyer / Exporter</option>
        <option value="field_officer">🧑‍🌾 Field Officer</option>
        <option value="quality_officer">🔬 Quality Officer</option>
        <option value="lab">🧪 Laboratory Staff</option>
        <option value="admin">⚙️ Administrator / NGO</option>
      </select>
    </div>
    
    <button type="submit" class="btn btn-p" style="width:100%;padding:14px">Create Account</button>
  </form>
  
  <div style="margin-top:20px;text-align:center;font-size:0.85rem;color:var(--tx2)">
    Already have an account? <a href="/login">Login here</a>
  </div>
</div>